	/* Filter functions */
	var rangeSliders = ['routelength','drivingTimeTotal'];
	jQuery(rangeSliders).each(function(i,e) {
		if (jQuery("#"+e+"Slider").length > 0) {
			var min = parseInt(jQuery("#"+e+"Slider").parent().find('.fWSMin').html());
			var max = parseInt(jQuery("#"+e+"Slider").parent().find('.fWSMax').html());
			var unit = jQuery("#"+e+"Slider").parent().data('unit');

			if (jQuery("#"+e+"Slider").parent().data('start-min')) {
				var startupMin = jQuery("#"+e+"Slider").parent().data('start-min');
			} else {
				var startupMin = min;
			}

			if (jQuery("#"+e+"Slider").parent().data('start-max')) {
				var startupMax = jQuery("#"+e+"Slider").parent().data('start-max');
			} else {
				var startupMax = max;
			}

			jQuery("#"+e+"Slider").slider({
				range: true,
				min: min,
				max: max,
				values: [startupMin, startupMax],
				slide: function( event, ui ) {
					jQuery( "#"+e+"Amount" ).val(
						ui.values[ 0 ] + " " + unit + " - " + ui.values[ 1 ] + " " + unit
					);
				},
				change : function() {
                    jQuery('#filterForm').submit();
                }
			});
			jQuery("#"+e+"Amount" ).val(
				jQuery( "#"+e+"Slider" ).slider( "values", 0 ) + " " + unit + " - " + jQuery( "#"+e+"Slider" ).slider( "values", 1 )+ " " + unit
			);
		}
	});



	var sliders = ['altitudeUp','altitudeDown','drivingTimeUphill','drivingTimeDownhill','walkingTimeUphill','vicinity','time'];
	jQuery(sliders).each(function(i,e) {
		if (jQuery("#"+e+"Slider").length > 0) {
			var max = parseInt(jQuery("#"+e+"Slider").parent().find('.fWSMax').html());
			var unit = jQuery("#"+e+"Slider").parent().data('unit');
			if (jQuery("#"+e+"Slider").parent().data('start-max')) {
				var startupMax = jQuery("#"+e+"Slider").parent().data('start-max');
			} else {
				var startupMax = max;
			}

			jQuery("#"+e+"Slider").slider({
				range: "min",
				min: 0,
				max: max,
				value: startupMax,
				slide: function( event, ui ) {
					jQuery( "#"+e+"Amount" ).val(
						ui.value + " " + unit
					);
				},
				change : function() {
                    jQuery('#filterForm').submit();
                }
			});
			jQuery("#"+e+"Amount" ).val(
				jQuery( "#"+e+"Slider" ).slider( "value" )+ " " + unit
			);
		}
	});

