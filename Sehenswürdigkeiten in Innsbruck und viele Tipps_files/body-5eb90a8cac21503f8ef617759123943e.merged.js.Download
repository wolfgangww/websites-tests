    /* next prev */
    jQuery('#mobileNavi .next').on('click touch', function() {
        var curTree = jQuery(this).closest('div');
        var next = (parseInt(jQuery('#mobileNavi').attr('data-cur')) * 100) + 100;
        var level = parseInt(jQuery('#mobileNavi').attr('data-cur'));
        var curHref = jQuery(this).prev().attr('href');

        jQuery('#mobileNavi').css('margin-left', '-' + next + '%');
        jQuery('#mobileNavi').attr('data-cur', level + 1);

        jQuery('#mobileNavi div > a[href="' + curHref + '"]').closest('div').addClass('actTree');
        jQuery('#mobileNavi div > a[href="' + curHref + '"]').closest('div').siblings().removeClass('actTree');

        var teaserPid = findTeaser(curTree.find('> a').attr('data-page'), 0);
    });

    jQuery('#mobileNavi .prev').on('click touch', function() {
        var curTree = jQuery(this).closest('div');
        var prev = (parseInt(jQuery('#mobileNavi').attr('data-cur')) * 100) - 100;
        var level = parseInt(jQuery('#mobileNavi').attr('data-cur'));
        var curHref = jQuery(this).next().attr('href');

        jQuery('#mobileNavi').css('margin-left', '-' + prev + '%');
        jQuery('#mobileNavi').attr('data-cur', level - 1);

        jQuery('#mobileNavi li[data-doktype="1"] > a[href="' + curHref + '"]').closest('div').addClass('actTree');
        jQuery('#mobileNavi li[data-doktype="1"] > a[href="' + curHref + '"]').closest('div').siblings().removeClass('actTree');

        var teaserPid = findTeaser(curTree.find('> a').attr('data-page'), 0);

        setTimeout(function() {
            curTree.removeClass('actTree');
        }, 500);
    });

