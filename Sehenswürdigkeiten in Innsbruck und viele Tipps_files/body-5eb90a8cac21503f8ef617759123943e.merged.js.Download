function changeDetailTeaserSizes() {
	var cDataEnd = jQuery('.cDData').offset().top + jQuery('.cDData').outerHeight();
	var teaserStart = jQuery('.cDDCTeaser').eq(0).offset().top;

	if (teaserStart > cDataEnd) { /* Teaser are starting below cData so fill width right from the beginning */
		jQuery('.cDDCTeaser').each(function(i,e) {
			var cur = jQuery(this);

			switch (i) {
				case 2:
				case 7:
				case 13:
					cur.removeClass("cDDCT-3-12").addClass("cDDCT-6-12");
				break;
			}

			switch (i) {
				case 10:
					cur.removeClass("cDDCT-3-12").addClass("cDDCT-12-12");
				break;
			}

			switch (i) {
				case 2:
				case 6:
				case 9:
				case 10:
				case 13:
					cur.css('margin-right',0);
				break;
			}

			if ((i > 13) && ((i-1)%4 == 0)) {
				cur.css('margin-right',0);
			}
		});
	} else { /* Teaser are starting left of cData so only half width ... */
		var last = 0;
		jQuery('.cDDCTeaser').each(function(i,e) {
			var cur = jQuery(this);


			switch (i) {
				case 2:
				case 7:
				case 13:
					cur.removeClass("cDDCT-3-12").addClass("cDDCT-6-12");
				break;
			}

			switch (i) {
				case 10:
					cur.removeClass("cDDCT-3-12").addClass("cDDCT-12-12");
				break;
			}

			switch (i) {
				case 10:
					cur.removeClass("cDDCT-3-12").addClass("cDDCT-12-12");
				break;
			}

			/*if (i == 2) {
				jQuery('.cDDCTeaser').eq(i-1).css('margin-right',0);
				cur.before('<div style="clear: both;"></div>');
			} else if (i > 2) {
				*/
				if ((last > 0) && (last != cur.offset().top) && ((cur.offset().top - last) < 330)) {
					cur.before('<div style="clear: both;"></div>');
					jQuery('.cDDCTeaser').eq(i-1).css('margin-right',0);
				} else {
					if ((last > 0) && (last != cur.offset().top) && ((cur.offset().top - last) >= 330)) {
						var beforeOffset = cur.offset().top;
						cur.css('margin-right',0);
						if (beforeOffset == cur.offset().top) {
							cur.css('margin-right','20px');
						}
					}
				}
			/*}*/


			last = cur.offset().top;
		});
	}



}

function getURLParameter(sParam) {
    var sPageURL = window.location.search.substring(1);
    var sURLVariables = sPageURL.split('&');

    for (var i = 0; i < sURLVariables.length; i++){
        var sParameterName = sURLVariables[i].split('=');

        if (sParameterName[0] == sParam){
            return sParameterName[1];
        }
    }
}

function inArray(needle, haystack) {
    var length = haystack.length;
    for(var i = 0; i < length; i++) {
        if(typeof haystack[i] == 'object') {
            if(arrayCompare(haystack[i], needle)) return true;
        } else {
            if(haystack[i] == needle) return true;
        }
    }
    return false;
}

window.addEventListener("orientationchange", function() {
	updateHeaderVideo();
}, false);

var player;
var headerVideoId = 'headerVideo';

function GetIEVersion() {

  var sAgent = window.navigator.userAgent;
  var Idx = sAgent.indexOf("MSIE");

  // If IE, return version number.
  if (Idx > 0)
    return parseInt(sAgent.substring(Idx+ 5, sAgent.indexOf(".", Idx)));

  // If IE 11 then look for Updated user agent string.
  else if (!!navigator.userAgent.match(/Trident\/7\./))
    return 11;

  else
    return 0; //It is not IE
}

function updateHeaderVideo() {
	if (jQuery('#headerVideo').length > 0) {
		if (player) {
			player.stopVideo();
			player.destroy();
			player = null;
		}

		setTimeout(function() {
			if ((jQuery(window).height()/jQuery(window).width()) <= 0.5625) {
				/* width 100% */
				var yTHeight = parseInt(jQuery(window).width()*0.5625)+1;
				var yTWidth = jQuery(window).width()+1;
			} else {
				/* height 100% */
				var yTHeight = jQuery(window).height()+1;
				var yTWidth = parseInt(jQuery(window).height()*(1/0.5625))+1;
			}

			player = new YT.Player(headerVideoId, {
				height: yTHeight,
				width: yTWidth,
				videoId: jQuery('#headerVideo').parent().data('youtubehash'),
				playerVars: {
					rel: 0,
					showinfo: 0,
					loop: 1,
					autoplay: 1,
					controls: 0
				},
				events: {
					'onReady': startYtPlay,
					'onStateChange': onPlayerStateChange
				}
			});

			function startYtPlay(event) {
				event.target.mute();
				event.target.setVolume(0);
				event.target.playVideo();
			}

			function onPlayerStateChange(event) {
				if ((event.data === 0) || (event.data === 2)) {
					player.seekTo(0);
				}
			}
		},500);
	}
}

