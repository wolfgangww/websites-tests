	if (jQuery('#dCMap').length > 0) {
		let contwiseDCEMap;
		let contwiseDCEMapId = '#dCMap';

		contwiseDCEMap = new nefos.Page({
			mapContainer: contwiseDCEMapId,
			disableHashHandling: true,
			view: new nefos.EmptyView(),
			requestHost: "https://tirol.mapservices.eu",
			requestBasePath: "nefos_app",
			systemName: "nefos_tirol",
			includeCSS: true
		});

		contwiseDCEMap.addEventListener('initialisationComplete', function(){
			var topLeftLat = -90;
			var topLeftLng = -90;
			var bottomRightLat = 90;
			var bottomRightLng = 90;
			var contwiseDCEMarker = [];
			var lastMarker;

			jQuery('.dCPoi').each(function(i,e) {

				/*
				https://www.innsbruck.info/fileadmin/templates/images/contwise.png
				https://www.innsbruck.info/fileadmin/templates/images/contwiseAct.png
				 */

				let curLat = jQuery(this).data('lat');
				let curLng = jQuery(this).data('lng');
				let curTitle = jQuery(this).data('title');
				let curLink = jQuery(this).data('link');
				let curIcon = "https://www.innsbruck.info/fileadmin/templates/images/contwise.png";
				let curIconAct = "https://www.innsbruck.info/fileadmin/templates/images/contwiseAct.png";

				if (jQuery(this).data('color') == 'grey') {
					contwiseDCEMarker.push(createContwiseDCEMarker(curIcon, curLat, curLng, curTitle));
				} else {
					contwiseDCEMarker.push(createContwiseDCEMarker(curIconAct, curLat, curLng, curTitle));
				}

				contwiseDCEMarker[i].addEventListener("click", function() {
					window.location=curLink;
				});
				contwiseDCEMap.addUserMapObject(contwiseDCEMarker[i]);

				if (curLat > topLeftLat) {
					topLeftLat = curLat;
				}
				if (curLng > topLeftLng) {
					topLeftLng = curLng;
				}
				if (curLat < bottomRightLat) {
					bottomRightLat = curLat;
				}
				if  (curLng < bottomRightLng) {
					bottomRightLng = curLng;
				}
			});

			var latDiff = topLeftLat - bottomRightLat;
			var lngDiff = topLeftLng - bottomRightLng;

			contwiseDCEMap.setMapCenter(new nefos.LatLng(topLeftLat-latDiff/2,topLeftLng-lngDiff/2));

			if (window.innerWidth < 480) {
				contwiseDCEMap.setMapZoomLevel(9);
			} else if (window.innerWidth < 1024) {
				contwiseDCEMap.setMapZoomLevel(10);
			} else {
				contwiseDCEMap.setMapZoomLevel(11);
			}
		});
	}
	setTimeout(function() {
		updateOnResize();
	},300);

});

function createContwiseDCEMarker(icon, lat, lng) {
	var marker = new nefos.Marker({
		position: new nefos.LatLng(lat, lng),
		icon : {
			image: icon,
			width: 24,
			height: 30,
			anchor : {
				x: 0,
				y: 30
			},
		},
		clusterable: false,
		hoverable: true,
		clickable: true
	});
	return marker;
}

function updateCalculation() {
	let cur = Cookies.get('cardCat').split(',');
	let adults = jQuery('#cardCalcAdults').val();
	let kids = 0;
	let priceWithoutCard = 0;
	let priceWithCard = 0;

	for (let i = 1; i < 6; i++) {
		if (jQuery('#cardCalcAgeChild'+i).val() > 5) {
			kids++;
		}
	}

	jQuery(cur).each(function(i,e) {
		priceWithoutCard += parseFloat(jQuery('.pCCBox[data-place="'+e+'"]').data('price-adult-no-card'))*adults + parseFloat(jQuery('.pCCBox[data-place="'+e+'"]').data('price-kid-no-card'))*kids;
		priceWithCard += parseFloat(jQuery('.pCCBox[data-place="'+e+'"]').data('price-adult-with-card'))*adults + parseFloat(jQuery('.pCCBox[data-place="'+e+'"]').data('price-kid-with-card'))*kids;
	});

	let pricePublicTransport = parseFloat(jQuery('#pCCPublicTransport').data('daily-public-transport')/24*jQuery('.pCCCard.act').data('card')*adults) + parseFloat(jQuery('#pCCPublicTransport').data('daily-public-transport-kids')/24*jQuery('.pCCCard.act').data('card')*kids);
	let priceTotalWithoutCard = priceWithoutCard + pricePublicTransport;

	jQuery('#publicTransportDuration').html(jQuery('.pCCCard.act').data('card'));

	let priceCard = parseFloat(jQuery('.pCCCard.act').data('price')*adults) + parseFloat(jQuery('.pCCCard.act').data('price-kids')*kids);
	let priceTotalWithCard = priceWithCard + priceCard;

	jQuery('#priceWithoutCard').html(priceWithoutCard.toFixed(2));
	jQuery('#pricePublicTransport').html(pricePublicTransport.toFixed(2));
	jQuery('#priceWithCard').html(priceTotalWithCard.toFixed(2));

	let priceSaved = priceTotalWithoutCard - priceTotalWithCard;

	if (priceSaved < 0) {
		priceSaved = 0;
	}

	jQuery('#priceSaved').html(priceSaved.toFixed(2));
}

function updatePlaceList(cardCats) {
	jQuery('.pCCPlaces .pCCContent').empty();
	if (parseInt(cardCats.length) > 0) {
		jQuery('.pCCPage1 .pCCPlaces').show('fast');
		if (jQuery('.pCCPage1 .pCCCalc.act').length > 0) {
			jQuery('.pCCCalc .pCCHeader').trigger('click');
		}

		jQuery(cardCats).each(function(i,e) {
			var title = jQuery('.pCCBox[data-place="'+e+'"]').find('h3').html();
			jQuery('.pCCPlaces .pCCContent').append('<div class="pCCSelectedPlace">'+title+' <span data-place="'+e+'"><i class="fas fa-times"></i></span></div>');
		});

		jQuery('.pCCNext').removeClass('disabled');
	} else {
		jQuery('.pCCPage1 .pCCPlaces').hide('fast');
		if (jQuery('.pCCPage1 .pCCCalc.act').length == 0) {
			jQuery('.pCCCalc .pCCHeader').trigger('click');
		}
		jQuery('.pCCNext').addClass('disabled');
	}
}

function filterCardCalc(curCat,page=1) {
	counter = 0;
	jQuery('.pCCBoxes .pCCBox').hide('fast');
	jQuery('.pCCBoxes .pCCBox').each(function() {
		if (inArray(curCat,jQuery(this).data('categories').split(','))) {
			if (counter < page*9) {
				jQuery(this).show('fast');
				counter++;
			}
		}
	});

	setTimeout(function() {
		updateLoadMore(curCat);
	},300);
}

function filterCardCalcPage(curCat,page=1) {
	counter = 0;
	jQuery('.pCCBoxes .pCCBox').each(function() {
		if (inArray(curCat,jQuery(this).data('categories').split(','))) {
			if (counter < page*9) {
				jQuery(this).show('fast');
				counter++;
			}
		}
	});
	setTimeout(function() {
		updateLoadMore(curCat);
	},300);
}

function updateLoadMore(curCat) {
	counter = 0;
	counterVisible = 0;
	jQuery('.pCCBoxes .pCCBox').each(function() {
		if (inArray(curCat,jQuery(this).data('categories').split(','))) {
			counter++;
			if (jQuery(this).is(":visible")) {
				counterVisible++;
			}
		}
	});
	if (counter == counterVisible) {
		jQuery('.pCCLoadMore').hide();
	}
}

function parallaxFullScreenUpdate() {
	/* Image */
	setTimeout(function() {
		var targetBeginPos = parseInt(jQuery('.dFPSIFixed').offset().top - parseInt(jQuery(window).height() / 2) + parseInt(jQuery('.dFPSIFixed').height() / 2));
		var targetEndPos = parseInt(jQuery('.dFPSAnchor > div').offset().top) - parseInt(jQuery(window).height() / 2);

		jQuery(window).scroll(function() {
			if (jQuery(window).scrollTop() >= targetBeginPos) {
				if (jQuery(window).scrollTop() <= targetEndPos) {
					if (!jQuery('.dFPSIFixed').hasClass('act')) {
						jQuery('.dFPSIFixed').addClass('act');
						jQuery('.dFPSIFixed').css('top', (parseInt(jQuery(window).height() / 2) - parseInt(jQuery('.dFPSIFixed').height() / 2)) - 100);
					}
				} else {
					if (jQuery('.dFPSIFixed').hasClass('act')) {
						jQuery('.dFPSIFixed').removeClass('act');
						jQuery('.dFPSIFixed').css('top', (parseInt(targetEndPos) + parseInt(jQuery(window).height() / 2) - parseInt(jQuery('.dFPSIFixed').height() / 2) - 100));
						jQuery('.dFPSIFixed').css('position', 'absolute');
					}
				}
			} else {
				if (jQuery('.dFPSIFixed').hasClass('act')) {
					jQuery('.dFPSIFixed').removeClass('act');
					jQuery('.dFPSIFixed').css('position','relative');
					jQuery('.dFPSIFixed').css('top','auto');
				}
			}
		});

		/* Navi */
		var targetBeginPos = parseInt(jQuery('.dFPSNFixed').offset().top - parseInt(jQuery(window).height() / 2) + parseInt(jQuery('.dFPSNFixed').height() / 2));
		var targetEndPos = parseInt(jQuery('.dFPSAnchor > div').offset().top) - parseInt(jQuery(window).height() / 2);

		jQuery(window).scroll(function() {
			if (jQuery(window).scrollTop() >= targetBeginPos) {
				if (jQuery(window).scrollTop() <= targetEndPos) {
					if (!jQuery('.dFPSNFixed').hasClass('act')) {
						jQuery('.dFPSNFixed').addClass('act');
						jQuery('.dFPSNFixed').css('top', (parseInt(jQuery(window).height() / 2) - parseInt(jQuery('.dFPSNFixed').height() / 2)) + 60);
					}
				} else {
					if (jQuery('.dFPSNFixed').hasClass('act')) {
						jQuery('.dFPSNFixed').removeClass('act');
						jQuery('.dFPSNFixed').css('top', (parseInt(targetEndPos) + parseInt(jQuery(window).height() / 2) - parseInt(jQuery('.dFPSIFixed').height() / 2)));
						jQuery('.dFPSNFixed').css('position', 'absolute');
					}
				}
			} else {
				if (jQuery('.dFPSNFixed').hasClass('act')) {
					jQuery('.dFPSNFixed').removeClass('act');
					jQuery('.dFPSNFixed').removeAttr('style');
				}
			}
		});

		/* update cur Screen */
		jQuery(window).scroll(function() {
			var targetBeginPos = parseInt(jQuery('.dceFactsParallax').offset().top - jQuery('.dFPScreen:first-of-type').height());
			var curPos = jQuery(window).scrollTop();
			var screenHeight = jQuery(window).height();
			var screenNumber = 1;

			if ((curPos - targetBeginPos) > 0) {
				var screenNumber = Math.ceil(((curPos - targetBeginPos - (screenHeight / 2)) / screenHeight));
				if (screenNumber > jQuery('.dFPScreen').length) {
					screenNumber = jQuery('.dFPScreen').length;
				}
				if (screenNumber < 1) {
					screenNumber = 1;
				}
				if (!jQuery('.dFPSNFixed span:nth-of-type(' + screenNumber + ')').hasClass('act')) {

					jQuery('.dFPSNFixed span.act').removeClass('act');
					jQuery('.dFPSNFixed span:nth-of-type(' + screenNumber + ')').addClass('act');

					var newImg = jQuery('.dFPScreen:nth-of-type(' + screenNumber + ')').attr('data-image');

					jQuery('.dFPSIImage').attr('style', 'background-image: url(' + newImg + ')');
					if ((GetIEVersion() > 0) && (GetIEVersion() < 12)) {
						jQuery('.dFPSIFixed').css('background-image', 'url(' + newImg + ')');
					}
					updateClipPathPoly(jQuery('.dFPSImage svg'), parseInt(jQuery(window).width() / 20));
				}
			} else {
				jQuery('.dFPSNFixed span.act').removeClass('act');
			}
		});
	}, 2000);
}

