function updateSmallHeader() {
    if (jQuery('.dHSFullscreen').length > 0) {
        jQuery('.dHSFullscreen').height(parseInt(jQuery(window).height() - jQuery('#top').outerHeight())+1);
    }
}

function updateFullscreen() {
    jQuery('.dFSSVideo').each(function() {
        if (jQuery(window).width < 1024) {

        } else {
            jQuery(this).next().find('foreignObject:first-of-type > div').prepend(jQuery(this));
        }
    });

    jQuery('.dFSSContent').each(function() {
        var sliderContentHeight = jQuery(this).height();
		var windowHeight = jQuery(window).height();

        jQuery(this).css('top', (parseInt(windowHeight / 2)) - (parseInt(sliderContentHeight / 2)));
        jQuery(this).css('display', 'block');

    });

	setTimeout(function() {
		if ((jQuery('.topics2019').length > 0) && (jQuery(window).width() >= 1024)) {
			if (jQuery('.dceFullscreenSlider').length > 0) {
				jQuery('.dceFullscreenSlider .slick-dots').css('top',parseInt(jQuery('.dceFullscreenSlider').height() / 2)  + 180);
			}
		}
	}, 1000);

    if (jQuery('.dceFullscreenSlider').length > 0) {

        var slider = jQuery('.dceFullscreenSlider');
		if (jQuery('.topics2019').length > 0) {
			var height = jQuery(window).height()-52;
		} else {
			var height = jQuery(window).height();
		}

        var width = jQuery(window).width();
        var playerId;

        if (slider.hasClass('slick-initialized')) {
            slider.slick('unslick');
        }

        jQuery('.dFSSSvg').each(function() {
            var curW = parseInt(jQuery(this).width());
            var curH = parseInt(jQuery(this).height());
            var dFSSSvg = "300,0 " + curW + ",0 " + (curW - 300) + ',' + curH + ' ' + 0 + ',' + curH;

            jQuery(this).find('polygon').attr('points', dFSSSvg);
        });

        jQuery('.dFSSlide').height(height);
        jQuery('.dFSSlide').width(width);
		jQuery('.dFSSlide foreignObject').attr('height',height);
		jQuery('.dFSSlide foreignObject').height(height);

        if (jQuery('.dFSSVideo').length > 0) {
            var newWidth = parseInt(height * 1.7777777778);
            if (jQuery(window).width < 1024) {
                jQuery('.dFSSVideo').width(newWidth);
                jQuery('.dFSSVideo').css('margin-left', '-' + parseInt((parseInt(newWidth) - parseInt(width)) / 2) + 'px');
            } else {
                if (newWidth < jQuery('.dFSSVideo').width()) {
                    newWidth = jQuery('.dFSSVideo').width();
                    height = parseInt(newWidth / 1.7777777778);
                }
            }
        }

        setTimeout(function() {
			if (jQuery('.dceFullscreenSlider .dFSSlide').length > 1) {
				if (!slider.hasClass('slick-initialized')) {
					slider.slick({
						dots: true,
						arrows: false,
						infinite: true,
						speed: 500,
						autoplay: true,
						autoplaySpeed: 5000,
						pauseOnHover: false
					});
				}
				slider.on('beforeChange', function(event, slick, currentSlide) {
					if (slider.find('.slick-current .dFSSVideo iframe').length > 0) {
						videoId = slider.find('.slick-current .dFSSVideo iframe').attr('id');
						slider.find('.slick-current .dFSSVideo iframe').parent().html('<div id="' + videoId + '"></div>');
						jQuery('.slick-current').css('z-index', 'unset');
					}
				});

				if (slider.find('.slick-current .dFSSVideo').length > 0) {
					jQuery('.slick-current').css('z-index', 2);
					slider.slick('slickPause');

					slider.find('.slick-dots .slick-active').html('<span></span>');
					slider.find('.slick-dots .slick-active').addClass('dFSSVideoDot');

					var playerId = slider.find('.slick-current .dFSSVideo > div').attr('id');
					if (playerId) {
						var yTHash = jQuery('#' + playerId).parent().data('youtubehash');
						var player = new YT.Player(playerId, {
							height: height,
							width: newWidth,
							videoId: yTHash,
							playerVars: {
								rel: 0,
								showinfo: 0
							},
							events: {
								'onReady': onPlayerReady,
								'onStateChange': onPlayerStateChange
							}
						});
					}

					function onPlayerReady(event) {

						var duration = event.target.getDuration();

						slider.find('.slick-dots .slick-active span').attr('style', '-webkit-transition: all ' + duration + 's linear; -moz-transition: all ' + duration + 's linear; -ms-transition: all ' + duration + 's linear; -o-transition: all ' + duration + 's linear; transition: all ' + duration + 's linear; width: 100%;');

						event.target.mute();
						event.target.setVolume(0);
						event.target.playVideo();
					}

					function onPlayerStateChange(event) {
						if ((event.data === 0) || (event.data === 2)) {
							slider.find('.slick-dots .slick-active').html('');
							slider.find('.slick-dots .slick-active').removeClass('dFSSVideoDot');

							player.stopVideo();
							player.destroy();
							player = null;

							slider.slick('slickNext');
							slider.slick('slickPlay');
						}
					}
				}

				slider.on('afterChange', function(event, slick, currentSlide) {
					if (slider.find('.slick-current .dFSSVideo').length > 0) {
						jQuery('.slick-current').css('z-index', 2);
						slider.slick('slickPause');

						slider.find('.slick-dots .slick-active').html('<span></span>');
						slider.find('.slick-dots .slick-active').addClass('dFSSVideoDot');

						var playerId = slider.find('.slick-current .dFSSVideo > div').attr('id');
						if (playerId) {
							var yTHash = jQuery('#' + playerId).parent().data('youtubehash');
							var player = new YT.Player(playerId, {
								height: height,
								width: newWidth,
								videoId: yTHash,
								playerVars: {
									rel: 0,
									showinfo: 0
								},
								events: {
									'onReady': onPlayerReady2,
									'onStateChange': onPlayerStateChange2
								}
							});
						}

						function onPlayerReady2(event) {

							var duration = event.target.getDuration();

							slider.find('.slick-dots .slick-active span').attr('style', '-webkit-transition: all ' + duration + 's linear; -moz-transition: all ' + duration + 's linear; -ms-transition: all ' + duration + 's linear; -o-transition: all ' + duration + 's linear; transition: all ' + duration + 's linear; width: 100%;');

							event.target.mute();
							event.target.setVolume(0);
							event.target.playVideo();
						}

						function onPlayerStateChange2(event) {
							if ((event.data === 0) || (event.data === 2)) {
								slider.find('.slick-dots .slick-active').html('');
								slider.find('.slick-dots .slick-active').removeClass('dFSSVideoDot');

								player.stopVideo();
								player.destroy();
								player = null;

								slider.slick('slickNext');
								slider.slick('slickPlay');
							}
						}
					}
				});
			}
        }, 100);
    }

    if ((parseInt(jQuery('#curPid').html()) > 1) && (parseInt(jQuery('#curPid').html()) != 5750)) {
		if (jQuery(window).width() < 1024) {
			jQuery('#header').attr('style', 'padding-top: '+parseInt(jQuery('#top').outerHeight()+40)+'px !important;');
		} else {
			jQuery('#header').attr('style', 'padding-top: '+parseInt(jQuery('#top').outerHeight())+'px !important;');
		}
    }
}

function filterTeaser() {
	var row = 0;
	var rowcount = 0;
	jQuery('.dceTeasersFilter').find('.dTTeaser.show').each(function(i,e) {
		jQuery(this).attr('data-i',i);
	});

	jQuery('.dceTeasersFilter').find('.dTTeaser.show').each(function(i,e) {
		var col = parseInt(jQuery(this).data('col'));
		var done = parseInt(jQuery(this).attr('data-i'));
		var cur = jQuery(this);

		if (row == 12) {
			row = 0;
			rowcount++;
		}

		if ((row+col) > 12) {
			jQuery('.dceTeasersFilter').find('.dTTeaser.show').reverse().each(function() {
				if (parseInt(jQuery(this).attr('data-i')) > done) {
					/*console.log(jQuery(this).attr('data-i') + ' - ' + cur.attr('data-i')+' - '+ row + ' - ' + jQuery(this).data('col') + ' - ' + done);*/
					if ((row == 9) && (jQuery(this).data('col') == 3)) {
						jQuery(this).insertBefore(cur);
						filterTeaser();
						return false;
					}
					if ((row == 6) && (jQuery(this).data('col') == 6)) {
						jQuery(this).insertBefore(cur);
						filterTeaser();
						return false;
					}
				}
			});
			rowcount++;

			return false;
		} else {
			row += col;
		}
	});
	jQuery('.dceTeasersMore').hide();
	if (jQuery('.dceTeasers').height() > jQuery('.dceTeasersWrap').height()) {
		jQuery('.dceTeasersMore').show();
	}
}




jQuery.fn.reverse = [].reverse;

$.fn.refresh = function() {
	return $(this.selector);
};


