function calculateDatesDifference(dateFrom,dateTo){dateFrom=dateFrom.split(".");var objDateFrom=new Date(dateFrom[1]+"/"+dateFrom[0]+"/"+dateFrom[2]);dateTo=dateTo.split(".");var objDateTo=new Date(dateTo[1]+"/"+dateTo[0]+"/"+dateTo[2]),timeDiff=Math.abs(objDateTo.getTime()-objDateFrom.getTime()),diffDays=Math.ceil(timeDiff/(1e3*3600*24));return diffDays}
