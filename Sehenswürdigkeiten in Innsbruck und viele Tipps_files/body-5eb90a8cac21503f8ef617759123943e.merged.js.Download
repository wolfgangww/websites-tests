    if (jQuery('.dFOpeningtimes').length > 0) {
        var now = new Date();
        var nowTimeSec = parseInt(now.getHours()) * 3600 + parseInt(now.getMinutes()) * 60;
        var fromSec = 0;
        var toSec = 0;
        var curOpening;

        jQuery('.dFOpeningtimes').each(function() {
            curOpening = 'closed';

            jQuery(this).find(' > div[data-day' + now.getDay() + '="1"]').each(function() {

                var fromSecArray = jQuery(this).attr('data-from').split(':');
                fromSec = parseInt(fromSecArray[0]) * 3600 + parseInt(fromSecArray[1]) * 60;

                var toSecArray = jQuery(this).attr('data-to').split(':');
                toSec = parseInt(toSecArray[0]) * 3600 + parseInt(toSecArray[1]) * 60;

                if ((nowTimeSec > fromSec) && (nowTimeSec < toSec)) {
                    curOpening = 'open';
                }
            });

            jQuery(this).find('.dFOStatus').addClass(curOpening);
            jQuery(this).find('.dFOStatus').html(jQuery(this).find('.dFOStatus').data(curOpening));
        });
    }

