		var url = jQuery('.pluginNewsroom .load-more-items').data('url');
		var format = 'html';

		delay(function(){
			jQuery.ajax({
				type: "POST",
				url: url,
				headers: {
					'Cache-Control': 'no-cache, no-store, must-revalidate',
					'Pragma': 'no-cache',
					'Expires': '0'
				},
				dataType: format,
				data: {
					page: 0,
					sword: jQuery('#pNFind').val()
				},
				success: function (content) {

					if (content == '') {
						jQuery('.pNList').html(jQuery('.pN404').html());
					} else {
						jQuery('.pNList').html(content);
					}
					cur.attr('data-page',1);
				}
			});
		}, 500);
	});

