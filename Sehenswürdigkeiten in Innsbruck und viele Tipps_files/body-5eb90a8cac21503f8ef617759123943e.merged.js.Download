            jQuery('#top .act').removeClass('act');
            stickyNavi(0);
        } else {
            jQuery('#tTFContent').html(jQuery('#' + jQuery(this).data('target')).html());
            jQuery('#top .act').removeClass('act');
            jQuery(this).addClass('act');
            jQuery('#topTargetFull').addClass('act');
            stickyNavi(1);
        }

