		jQuery(this).toggleClass('tFHide tFShow');
		jQuery(this).closest('.filter').find('.fWrap').slideToggle('fast');

		if (jQuery(this).hasClass('tFHide')) {
			jQuery(this).html(jQuery(this).data('hide'));
			if (jQuery('.fWAccHead.act').length == 0) {
				jQuery('.fWrap > div:nth-of-type(1) .fWAccHead').trigger('click');
			}
		} else {
			jQuery(this).html(jQuery(this).data('show'));
		}
	});
