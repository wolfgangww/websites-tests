    jQuery('#newsletterSubmit').on('click touch', function() {
        if (jQuery('.dNSteps .slick-current input').length > 0) {
            if (jQuery('.dNSteps .slick-current input:valid').length > 0) {
                var next = parseInt(jQuery('#newsletterSubmit span').html()) + 1;

                if (next > 4) {
					jQuery('#newsletterSubmit').hide();
                    jQuery.post( "/fileadmin/templates/scripts/newsletterSub.php", {
						email: jQuery('#newsletterEmail').val(),
						firstname: jQuery('#newsletterFirstname').val(),
						lastname: jQuery('#newsletterLastname').val(),
						salutation: jQuery('#newsletterSalutation').val(),
						lang: jQuery('#langNavi').html(),
						frm:  jQuery('#frm').html(),
						acc:  jQuery('#acc').html(),
						url: window.location.href
					}).done(function(response) {
						jQuery('#newsletterTargetMessage').html(response);
						jQuery('.dNSteps').slick('slickNext');

						var dataObject = {
							'event': 'Newsletter',
							'category': 'Newsletter',
							'label': 'Newsletter Anmeldung'
						};
						if(typeof dataLayer != 'undefined'){
							dataLayer.push(dataObject);
							console.log(dataObject);
						}
					});
                } else {
                    jQuery('.dNSteps').slick('slickNext');
                    jQuery('#newsletterSubmit span').html(next);
                }
            } else {
                /* trigger validation message */
                jQuery('#newsletterSubButton').click();
            }
        } else if (jQuery('.dNSteps .slick-current select').length > 0) {
            jQuery('.dNSteps').slick('slickNext');
            jQuery('#newsletterSubmit span').html(parseInt(jQuery('#newsletterSubmit span').html()) + 1);
        }
    });

