function updateSVGPolygons() {
    /* updates polyogon points within svgs */
    jQuery('#content svg').each(function() {
        if ((parseInt(jQuery(this).attr('data-width')) > 0) && (parseInt(jQuery(this).attr('data-height')) > 0)) {
            var srcWidth = parseInt(jQuery(this).attr('data-width'));
            var srcHeight = parseInt(jQuery(this).attr('data-height'));
            var curWidth = parseInt(jQuery(this).width());
            var ratio = jQuery(this).width() / srcWidth;
            var curHeight = parseInt(srcHeight * ratio);
            var poly = jQuery(this).find('polygon').attr('points');
            var allCoords = poly.split(' ');

            var newAllCoords = [];
            jQuery(allCoords).each(function(i, e) {
                var newCoords = [];
                if (e != '') {
                    var coords = e.split(',');
                    newCoords.push(parseInt(coords[0] * ratio));
                    newCoords.push(parseInt(coords[1] * ratio));
                }
                newAllCoords.push(newCoords.join(','));
            });

            jQuery(this).find('polygon').attr('points', newAllCoords.join(' '));
            jQuery(this).attr('data-width', curWidth);
            jQuery(this).attr('data-height', curHeight);
            jQuery(this).height(curHeight);
        }
    });
}

function updateClipPathPoly(theSVG, variation) {
    var curHeight = theSVG.height();
    var curWidth = theSVG.width();

    if (variation > 90) {
        variation = 90;
    }

    theSVG.each(function() {
        var upperLeft = Math.floor((Math.random() * variation) + 1) + ',' + Math.floor((Math.random() * variation) + 1);
        var upperRight = (curWidth - Math.floor((Math.random() * variation) + 1)) + ',' + Math.floor((Math.random() * variation) + 1);
        var lowerRight = (curWidth - Math.floor((Math.random() * variation) + 1)) + ',' + (curHeight - Math.floor((Math.random() * variation) + 1));
        var lowerLeft = Math.floor((Math.random() * variation) + 1) + ',' + (curHeight - Math.floor((Math.random() * variation) + 1));

        jQuery(this).find('polygon').attr('points', upperLeft + ' ' + upperRight + ' ' + lowerRight + ' ' + lowerLeft);

        var upperLeft = Math.floor((Math.random() * variation) + 1) + ',' + Math.floor((Math.random() * variation) + 1);
        var upperRight = (curWidth - Math.floor((Math.random() * variation) + 1)) + ',' + Math.floor((Math.random() * variation) + 1);
        var lowerRight = (curWidth - Math.floor((Math.random() * variation) + 1)) + ',' + (curHeight - Math.floor((Math.random() * variation) + 1));
        var lowerLeft = Math.floor((Math.random() * variation) + 1) + ',' + (curHeight - Math.floor((Math.random() * variation) + 1));

        jQuery(this).find('animate').attr('to', upperLeft + ' ' + upperRight + ' ' + lowerRight + ' ' + lowerLeft);
    });
}

function initSlickTeaser() {
    if (jQuery('#mobileNaviTeaser .dNTSlider').length > 0) {
        jQuery('#mobileNaviTeaser .dNTSlider .dNTSSlide').each(function() {
            var slickTeaserHeight = 310;
			if (jQuery(this).width() > 0) {
				if (jQuery(this).width() < 310) {
					var slickTeaserHeight = jQuery(this).width();
				}
			}
            jQuery(this).height(slickTeaserHeight);
        });
    }
    jQuery('#mobileNaviTeaser .dNTSlider').slick({
        dots: true,
        arrows: false,
        infinite: false,
        speed: 500,
        autoplay: true,
        slidesToShow: 3,
        slidesToScroll: 3,
        responsive: [{
            breakpoint: 1300,
            settings: {
                slidesToShow: 2,
                slidesToScroll: 2,
                infinite: true,
                dots: true
            }
        }, {
            breakpoint: 768,
            settings: {
                slidesToShow: 1,
                slidesToScroll: 1
            }
        }]
    });
}

function findTeaser(pid, counter) {
    counter++;
    if (counter > 5) {
        return 1;
    }
    if (jQuery('.dceNaviTeaser[data-page="' + pid + '"]').length > 0) {
        return pid;
    } else {
        thePid = findTeaser(jQuery('a[data-page="' + pid + '"]').closest('[data-level]').prev().find('a[data-page]').attr('data-page'), counter);
        return thePid;
    }
}

var resizeTimer;
var scrollTimer;
var lastScrollTop = 0;

jQuery(window).resize(function() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(updateOnResize(), 100);

    svgHeight();
});

jQuery(window).scroll(function() {
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(updateOnScroll(), 10);
});

function updateFactBox() {
    jQuery('.dceFactboxTour, .dceFactboxEvent, .dceFactbox').removeAttr('style');
    if ((jQuery('.dceFactboxTour, .dceFactboxEvent, .dceFactbox').length > 1) && (jQuery(window).width() >= 768)) {
        var curMaxHeight = 0;
        jQuery('.dceFactboxTour, .dceFactboxEvent, .dceFactbox').each(function() {
            if (jQuery(this).height() > curMaxHeight) {
                curMaxHeight = jQuery(this).height();
            }
        });
        jQuery('.dceFactboxTour, .dceFactboxEvent, .dceFactbox').height(curMaxHeight);
    }
}

function updateGallery() {
    if (jQuery('.dGImage2, .dGImage3').length > 0) {
        jQuery('.dGImage2, .dGImage3').each(function() {
            jQuery(this).height(parseInt(jQuery(this).width() * 0.75));
        });
    }
}

function polyText() {
    if (jQuery('.dcePolygonText').length > 0) {
        var curTarget = parseInt(jQuery(window).scrollTop()) + parseInt(jQuery(window).height() / 2);

        jQuery('.dcePolygonText').each(function() {
            if (jQuery(this).offset().top > curTarget) {
                jQuery(this).removeClass('act');
            } else {
                jQuery(this).addClass('act');
            }
        });
    }
}

