if(!String.prototype.includes)String.prototype.includes=function(search,start){'use strict';if(search instanceof RegExp)throw TypeError('first argument must not be a RegExp');if(start===undefined)start=0;return this.indexOf(search,start)!==-1};
var position = $(window).scrollTop();
jQuery(document).ready(function() {
	jQuery("#basketStart").datepicker({
		minDate: 0,
	});
	jQuery("#basketStartdate").datepicker({
		minDate: 0,
	});
	jQuery('.dBCLink a').on('click touch',function(e) {
		e.preventDefault();

		if (jQuery('#basketStartdate').val()) {
			let duration;
			let url = jQuery(this).attr('href');
			switch(jQuery('.dBCCard.act .dBCTitle').html()) {
				default:
					duration = 48;
					break;

				case "24h":
					duration = 24;
					break;

				case "72h":
					duration = 72;
					break;
			}

			jQuery.ajax({
				type: "POST",
				url: "/typo3conf/ext/webx_cardcalc/Resources/Public/PHP/makeBasket.php",
				async: false,
				headers: {
					'Cache-Control': 'no-cache, no-store, must-revalidate',
					'Pragma': 'no-cache',
					'Expires': '0'
				},
				dataType: 'html',
				data: {
					duration: duration,
					adults: jQuery('#buyCardAdults').val(),
					kids: jQuery('#buyCardKids').val(),
					start: jQuery('#basketStartdate').val()
				},
				success: function (basket) {
					window.location = url+'?quote='+basket;
				}
			});
		} else {
			let foo = document.getElementById("basketStartdateForm");
			foo.reportValidity();
		}
	});

	jQuery('.pCCFinalize a').on('click touch',function(e) {
		e.preventDefault();

		if (jQuery('#basketStart').val()) {
			let duration = jQuery('.pCCCard.act').data('card');
			let url = jQuery(this).attr('href');

			jQuery.ajax({
				type: "POST",
				url: "/typo3conf/ext/webx_cardcalc/Resources/Public/PHP/makeBasket.php",
				async: false,
				headers: {
					'Cache-Control': 'no-cache, no-store, must-revalidate',
					'Pragma': 'no-cache',
					'Expires': '0'
				},
				dataType: 'html',
				data: {
					duration: duration,
					adults: jQuery('#cardCalcAdults').val(),
					kids: 0,
					start: jQuery('#basketStart').val()
				},
				success: function (basket) {
					window.location = url+'?quote='+basket;
				}
			});
		} else {
			let foo = document.getElementById("basketStartForm");
			foo.reportValidity();
		}
	});

	jQuery('.coreLink1').on('click touch',function() {
		if (jQuery('.coreLink1Target').length > 0) {
			window.location=jQuery('.coreLink1Target').attr('href');
		}
	});
	jQuery('.coreLink2').on('click touch',function() {
		if (jQuery('.coreLink2Target').length > 0) {
			window.location = jQuery('.coreLink2Target').attr('href');
		}
	});
	jQuery('.coreLink3').on('click touch',function() {
