	jQuery('.dGOFilter input').on('change',function() {
		let streams = [];
		jQuery('#dGOTarget .dGOStream').css('height','1px');
		jQuery('.dGOFilter input:checked').each(function(){
			stream = jQuery(this).val();
			streams.push(stream);
			jQuery('#dGOTarget .dGOStream[data-stream="'+stream+'"]').css('height','auto');
		});
		Cookies.set('giggle-'+parseInt(jQuery('#curPid').html()), JSON.stringify(streams), { expires: 1 });

		if (jQuery(this).prop('checked')) {
			stream = jQuery(this).val();
			if (jQuery('#top').length > 0) {
				$('html, body').animate({
					scrollTop: jQuery('#dGOTarget .dGOStream[data-stream="'+stream+'"]').offset().top-jQuery('#top').outerHeight()
				}, 250);
			} else {
				$('html, body').animate({
					scrollTop: jQuery('#dGOTarget .dGOStream[data-stream="'+stream+'"]').offset().top
				}, 250);
			}
		}
	});

