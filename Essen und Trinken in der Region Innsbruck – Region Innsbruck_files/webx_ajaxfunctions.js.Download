
function BookingEmo_ajaxCall(request, parameters) {

    if (EmoAjax.config.requestURI == "undefined") {
        console.log("EmoAjax not initialized!");
        EmoAjax.config.requestURI = "/";
    }

    // override
    //EmoAjax.config.requestURI = "/";

    // console.log(parameters);

    //console.log(EmoAjax.config.requestURI);


    if (typeof parameters == "undefined") {
        parameters = {
            'emptyAjaxRequest': 1
        };
    }

    calldata = {
        eID: "WebxBookingemo",
        'action': request['action'],
        'plugin': request['plugin'],
    };

    calldata[request['plugin']] = parameters;


    jQuery.ajax({
        async: 'true',
        url: EmoAjax.config.requestURI,
        type: 'POST',
        data: calldata,
        dataType: "json",

        success: function(result) {
            jQuery.each(result, function() {
                switch (this.type) {
                    case "innerHTMLAppend":
                        // console.log(this);
                        jQuery(this.selector).append(this.content);
                        break;
                    case "innerHTML":
                        jQuery(this.selector).html(this.content);
                        break;

                    case "functionCall":
                        eval(this.content);
                        break;

                    case  "markers":
                        if (this.selector) {
                            eval(this.selector+'.removeMarkers()');
                            eval(this.selector+'.buildMarkers('+JSON.stringify(this.content)+')');
                            // map.removeMarkers();
                            // map.buildMarkers(this.content);
                        }
                        return false;
                    case "markersPopUp":
                        eval(this.selector+'.showPopUp(\''+this.content.replace(/(\r\n|\n|\r)/gm, "")+'\')');
                        // map.showPopUp(this.content);
                    default:
                        break;
                }
            });

        },
        error: function(error) {
            console.log(error);
        }
    });
}


