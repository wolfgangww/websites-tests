function updateBuyCard() {
	if (jQuery('.dBCCards').length > 0) {
		let adults = parseInt(jQuery('#buyCardAdults').val());
		let kids = parseInt(jQuery('#buyCardKids').val());

		let total = adults*parseFloat(jQuery('.dBCCard.act .dBCPriceAdults').data('price-adults')) + kids*parseFloat(jQuery('.dBCCard.act .dBCPriceKids').data('price-kids'));

		jQuery('#dBCCalcTotal').html(total.toFixed(2).replace(/\./,','));
	}
}

function updateVideo() {
	if (jQuery('.resizeVideo').length > 0) {
		jQuery('.resizeVideoWrap, .resizeVideo').removeAttr('style');

		/* videos are always 16:9 */
		var factor = 9/16;
		var vPWidth = jQuery(window).width();
		var vPHeight = jQuery(window).height();

		jQuery('.resizeVideoWrap').width(vPWidth);
		jQuery('.resizeVideoWrap').height(vPHeight);

		if ((vPWidth*factor) > vPHeight) {
			/* zu hoch */
			jQuery('.resizeVideo').width(vPWidth);
			jQuery('.resizeVideo').height(parseInt(vPWidth*factor));

			var hMargin = parseInt((parseInt(vPWidth*factor)-vPHeight)/2);
			jQuery('.resizeVideo').css('margin-top','-'+hMargin+'px');
		} else {
			/* zu breit */
			jQuery('.resizeVideo').width(parseInt(vPHeight/factor));
			jQuery('.resizeVideo').height(vPHeight);

			var vMargin = parseInt((parseInt(vPHeight/factor)-vPWidth)/2);
			jQuery('.resizeVideo').css('margin-left','-'+vMargin+'px');
		}
	}
}

