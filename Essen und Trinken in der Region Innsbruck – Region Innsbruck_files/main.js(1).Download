		jQuery.post( "/fileadmin/templates/scripts/newsletterFormSubmit.php", {
			email: jQuery('#dNFEmail').val(),
			firstname: jQuery('#dNFFirstname').val(),
			lastname: jQuery('#dNFLastname').val(),
			firma: company,
			salutation: jQuery('#dNFSalutation').val(),
			title: jQuery('#dNFTitle').val(),
