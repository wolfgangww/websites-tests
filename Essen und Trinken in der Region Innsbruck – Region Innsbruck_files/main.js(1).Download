        }
    /*} else {
        if (force == 1) {
            jQuery('#top').addClass('whiteBg');
            jQuery('#logo img').attr('src', jQuery('#logo img').data('red'));
            if (!jQuery('#topTargetFull').hasClass('act') && !jQuery('#topLangTarget').hasClass('act')) {
