var position = $(window).scrollTop();
jQuery(document).ready(function() {
	jQuery("#basketStart").datepicker({
		minDate: 0,
	});
	jQuery("#basketStartdate").datepicker({
		minDate: 0,
	});
	jQuery('.dBCLink a').on('click touch',function(e) {
		e.preventDefault();

		if (jQuery('#basketStartdate').val()) {
			let duration;
			let url = jQuery(this).attr('href');
			switch(jQuery('.dBCCard.act .dBCTitle').html()) {
				default:
					duration = 48;
					break;

				case "24h":
					duration = 24;
					break;

				case "72h":
					duration = 72;
					break;
			}

			jQuery.ajax({
				type: "POST",
				url: "/typo3conf/ext/webx_cardcalc/Resources/Public/PHP/makeBasket.php",
				async: false,
				headers: {
					'Cache-Control': 'no-cache, no-store, must-revalidate',
					'Pragma': 'no-cache',
					'Expires': '0'
				},
				dataType: 'html',
				data: {
					duration: duration,
					adults: jQuery('#buyCardAdults').val(),
					kids: jQuery('#buyCardKids').val(),
					start: jQuery('#basketStartdate').val()
				},
				success: function (basket) {
					window.location = url+'?quote='+basket;
				}
			});
		} else {
			let foo = document.getElementById("basketStartdateForm");
			foo.reportValidity();
		}
	});

	jQuery('.pCCFinalize a').on('click touch',function(e) {
		e.preventDefault();

		if (jQuery('#basketStart').val()) {
			let duration = jQuery('.pCCCard.act').data('card');
			let url = jQuery(this).attr('href');

			jQuery.ajax({
				type: "POST",
				url: "/typo3conf/ext/webx_cardcalc/Resources/Public/PHP/makeBasket.php",
				async: false,
				headers: {
					'Cache-Control': 'no-cache, no-store, must-revalidate',
					'Pragma': 'no-cache',
					'Expires': '0'
				},
				dataType: 'html',
				data: {
					duration: duration,
					adults: jQuery('#cardCalcAdults').val(),
					kids: 0,
					start: jQuery('#basketStart').val()
				},
				success: function (basket) {
					window.location = url+'?quote='+basket;
				}
			});
		} else {
			let foo = document.getElementById("basketStartForm");
			foo.reportValidity();
		}
	});

	jQuery('.coreLink1').on('click touch',function() {
		if (jQuery('.coreLink1Target').length > 0) {
			window.location=jQuery('.coreLink1Target').attr('href');
		}
	});
	jQuery('.coreLink2').on('click touch',function() {
		if (jQuery('.coreLink2Target').length > 0) {
			window.location = jQuery('.coreLink2Target').attr('href');
		}
	});
	jQuery('.coreLink3').on('click touch',function() {
		if (jQuery('.coreLink3Target').length > 0) {
			window.location = jQuery('.coreLink3Target').attr('href');
		}
	});
	jQuery('.coreLink4').on('click touch',function() {
		if (jQuery('.coreLink4Target').length > 0) {
			window.location = jQuery('.coreLink4Target').attr('href');
		}
	});
	jQuery('.coreLink5').on('click touch',function() {
		if (jQuery('.coreLink5Target').length > 0) {
			window.location = jQuery('.coreLink5Target').attr('href');
		}
	});

	if (jQuery('.dceTeasersFilter').length > 0) {
		filterTeaser();
	}

	jQuery('.dceFilter > span').on('click touch',function() {
		jQuery('.dceFilter > span').removeClass('act');
		jQuery(this).addClass('act');
		var theCat = jQuery(this).data('cat');

		if (theCat == 0) {
			jQuery('.dceTeasersFilter .dTTeaser').addClass('show');
		} else {
			jQuery('.dceTeasersFilter').find('.dTTeaser').each(function(i,e) {
				var foo = jQuery(this).data('cat');
				var cats = foo.split(',');

				if (jQuery.inArray(theCat.toString(),cats) > -1) {
					if (!jQuery(this).hasClass('show')) {
						jQuery(this).addClass('show');
					}
				} else {
					if (jQuery(this).hasClass('show')) {
						jQuery(this).removeClass('show');
					}
				}
			});
		}
		filterTeaser();
	});

	jQuery('.dceTeasersMore').on('click touch',function(e) {
		e.preventDefault();

		jQuery('.dceTeasersWrap').css('max-height','none');
		jQuery('.dceTeasersMore').hide();
	});

	jQuery('.pCCLoadMore').on('click touch',function() {
		filterCardCalcPage(jQuery('.pCCCategory.act').data('category'),jQuery(this).attr('data-page'));
		jQuery(this).attr('data-page',parseInt(jQuery(this).attr('data-page'))+1);
	});

	jQuery('.dCOverlay').on('click touch',function() {
		jQuery(this).remove();
	});
	jQuery('.dBCInputWrap .fa-plus-square').on('click touch',function() {
		jQuery(this).closest('.dBCInputWrap').find('input').val(parseInt(jQuery(this).closest('.dBCInputWrap').find('input').val())+1);
		updateBuyCard();
	});
	jQuery('.dBCInputWrap .fa-minus-square').on('click touch',function() {
		if (parseInt(jQuery(this).closest('.dBCInputWrap').find('input').val()) > 0) {
			jQuery(this).closest('.dBCInputWrap').find('input').val(parseInt(jQuery(this).closest('.dBCInputWrap').find('input').val())-1);
			updateBuyCard();
		}
	});

	jQuery('.dBCCard').on('click touch',function() {
		jQuery('.dBCCard').removeClass('act');
		jQuery(this).addClass('act');
		updateBuyCard();
	});

	if (jQuery(window).width() < 1024) {
		jQuery('.pCCCalculator').insertAfter('.pCCFilterWrap');
	}
	jQuery('.pCCFilterLabel').on('click touch',function() {
		jQuery(this).toggleClass('act');
		jQuery('.pCCFilterContent').toggleClass('act');
	});
	jQuery('.pCCCards > div').on('click touch',function() {
		jQuery('.pCCCards > div').removeClass('act');
		jQuery(this).addClass('act');

		jQuery('.pCCFinalize a').attr('href',jQuery(this).data('url'));
	});

	jQuery('.pCCPage2 .pCCNext, .pCCPage2 .pCCNextIcon').on('click touch',function(){
		jQuery('.pCCPage2').hide('fast');
		jQuery('.pCCPage3').show('fast');
	});

	jQuery('.pCCPage2 .pCCPrev').on('click touch',function(){
		jQuery('.pCCPage2').hide('fast');
		jQuery('.pCCPage1').show('fast');
	});

	jQuery('.pCCPage3 .pCCNext, .pCCPage3 .pCCNextIcon').on('click touch',function(){
		jQuery('.pCCPage3').hide('fast');
		jQuery('.pCCPage4').show('fast');
		updateCalculation();
	});

	jQuery('.pCCPage3 .pCCPrev').on('click touch',function(){
		jQuery('.pCCPage3').hide('fast');
		jQuery('.pCCPage2').show('fast');
	});

	jQuery('.pCCPage4 .pCCPrev').on('click touch',function(){
		jQuery('.pCCPage4').hide('fast');
		jQuery('.pCCPage3').show('fast');
	});

	jQuery('.pCCInputs .fa-plus-square').on('click touch',function() {
		switch(jQuery(this).attr('for')) {
			case "cardCalcChildren":
				var max = 5;
				break;

			case "cardCalcAgeChild1":
			case "cardCalcAgeChild2":
			case "cardCalcAgeChild3":
			case "cardCalcAgeChild4":
			case "cardCalcAgeChild5":
				var max = 15;
				break;

			default:
				var max = 100;
				break;
		}

		if (parseInt(jQuery('#'+jQuery(this).attr('for')).val()) < max) {
			jQuery('#' + jQuery(this).attr('for')).val(parseInt(jQuery('#' + jQuery(this).attr('for')).val()) + 1);
		}
	});

	jQuery('.pCCInputs .fa-minus-square').on('click touch',function() {
		if (parseInt(jQuery('#'+jQuery(this).attr('for')).val()) > 0) {
			jQuery('#'+jQuery(this).attr('for')).val(parseInt(jQuery('#'+jQuery(this).attr('for')).val())-1);
		}
	});

	jQuery('#cardCalcChildren').on('change',function() {
		jQuery('.pCCShowAge').not('.pCCShowAge'+jQuery(this).val()).find('input').val('0');
		jQuery('.pCCShowAge').not('.pCCShowAge'+jQuery(this).val()).hide('fast');

		jQuery('.pCCShowAge.pCCShowAge'+jQuery(this).val()).css('display', 'flex');
	});

	jQuery('i[for="cardCalcChildren"]').on('click touch', function() {
		jQuery('.pCCShowAge').not('.pCCShowAge'+jQuery('#cardCalcChildren').val()).find('input').val('0');
		jQuery('.pCCShowAge').not('.pCCShowAge'+jQuery('#cardCalcChildren').val()).hide('fast');

		jQuery('.pCCShowAge.pCCShowAge'+jQuery('#cardCalcChildren').val()).css('display', 'flex');
	});

	jQuery('.pCCPage1 .pCCNext').on('click touch',function() {
		jQuery('.pCCPage1').hide('fast');
		jQuery('.pCCPage2').show('fast');
	});

	jQuery(document).on("click",".pCCSelectedPlace span",function() {
		jQuery('.pCCBox[data-place="'+jQuery(this).attr('data-place')+'"] .pCCStar').trigger('click');
	});

	jQuery('.pCCHighlight .fa-star').on('click touch', function() {
		jQuery('.pCCBox[data-place="'+jQuery(this).closest('.pCCHighlight').attr('data-place')+'"] .pCCStar').trigger('click');
	});

	jQuery('.pCCCalc .pCCHeader').on('click touch',function() {
		if (jQuery(this).closest('.pCCCalc').hasClass('act')) {
			jQuery(this).closest('.pCCCalc').removeClass('act');
			jQuery(this).next().hide('fast');
		} else {
			jQuery(this).closest('.pCCCalc').addClass('act');
			jQuery(this).next().show('fast');
		}
	});

	if (Cookies.get('cardCat') && (jQuery('.pCCBoxes').length > 0)) {
		cardCats = Cookies.get('cardCat').split(',');
		jQuery('.pCCBoxes .pCCBox').each(function() {
			if (inArray(parseInt(jQuery(this).data('place')),cardCats)) {
				jQuery(this).find('.pCCStar').toggleClass('far fas');
				jQuery('.pCCHighlight[data-place="'+jQuery(this).data('place')+'"] .fa-star').toggleClass('far fas');
			}
		});

		updatePlaceList(cardCats);
	}

	jQuery('.pCCStar').on('click touch',function() {
		curPlace = jQuery(this).closest('.pCCBox').data('place');

		if (Cookies.get('cardCat')) {
			cardCats = Cookies.get('cardCat').split(',');
		} else {
			cardCats = [];
		}

		if (jQuery(this).hasClass('far')) {
			cardCats.push(parseInt(curPlace));
		}

		if (jQuery(this).hasClass('fas')) {
			for (var i = cardCats.length; i--;) {
				if (cardCats[i] == curPlace) cardCats.splice(i, 1);
			}
		}

		jQuery(this).toggleClass('far fas');
		jQuery('.pCCHighlight[data-place="'+curPlace+'"] .fa-star').toggleClass('far fas');
		Cookies.set('cardCat', cardCats.join(','));
		updatePlaceList(cardCats);
		updateCalculation();
	});

	jQuery('.pCCCategory').on('click touch', function() {
		jQuery('.pCCLoadMore').show();
		jQuery('.pCCLoadMore').attr('data-page',2);
		if (!jQuery(this).hasClass('act')) {
			jQuery('.pCCCategory').removeClass('act');
			jQuery(this).addClass('act');
		}
		filterCardCalc(jQuery(this).data('category'));
	});
	jQuery('.disableNavi > a').on('click touch',function(e) {
		e.preventDefault();
	});
	jQuery('.disableNavi').on('click touch',function(e) {
		if (jQuery(this).children('.toggleSub').length > 0) {
			jQuery(this).children('.toggleSub').trigger('click');
		}
	});
	if (jQuery('.resizeVideoWrap').length > 0) {
		if (jQuery('.resizeVideoWrap').attr('data-video') && jQuery(window).width() >= 1024) {
			jQuery('.resizeVideoWrap video').html('<source src="'+jQuery('.resizeVideoWrap').attr('data-video')+'" type="video/mp4"/>');
		}
	}

	jQuery('.giggleStream').on('click touch', function(e) {
		e.preventDefault();
		stream = jQuery(this).data('stream');

		jQuery('.dGOFilter input').prop('checked',false);
		jQuery('.dGOFilter input[value="'+stream+'"]').trigger('click');
	});

	if (jQuery('.dGOFilter input').length > 0) {
		setTimeout(function(){
			jQuery('#dGOTarget .dGOStream').css('height','1px');
			jQuery('.dGOFilter input:checked').each(function(){
				stream = jQuery(this).val();
				jQuery('#dGOTarget .dGOStream[data-stream="'+stream+'"]').css('height','auto');
			});
		},250);
	}

	if (jQuery('.dGOFilter').length > 0) {
		if (Cookies.get('giggle-'+parseInt(jQuery('#curPid').html()))) {
			streams = Cookies.get('giggle-'+parseInt(jQuery('#curPid').html()));
			if(streams) {
				jQuery(JSON.parse(streams)).each(function (i, e) {
					jQuery('input[value="'+e+'"]').prop('checked',true);
				});
			}
			jQuery('.dGOFilter input').trigger('change');
		}
	}

	jQuery('.dGOFilter input').on('change',function() {
		let streams = [];
		jQuery('#dGOTarget .dGOStream').css('height','1px');
		jQuery('.dGOFilter input:checked').each(function(){
			stream = jQuery(this).val();
			streams.push(stream);
			jQuery('#dGOTarget .dGOStream[data-stream="'+stream+'"]').css('height','auto');
		});
		Cookies.set('giggle-'+parseInt(jQuery('#curPid').html()), JSON.stringify(streams), { expires: 1 });

		if (jQuery(this).prop('checked')) {
			stream = jQuery(this).val();
			if (jQuery('#top').length > 0) {
				$('html, body').animate({
					scrollTop: jQuery('#dGOTarget .dGOStream[data-stream="'+stream+'"]').offset().top-jQuery('#top').outerHeight()
				}, 250);
			} else {
				$('html, body').animate({
					scrollTop: jQuery('#dGOTarget .dGOStream[data-stream="'+stream+'"]').offset().top
				}, 250);
			}
		}
	});

	$(document).on('keyup', '#bingSword', function () {
		if (jQuery('#bingSword').val()) {
			jQuery('#bingSword').next().addClass('actButton');
		} else {
			jQuery('#bingSword').next().removeClass('actButton');
		}
	});

	$(document).on('keyup', '#pCFind', function () {
		jQuery('.pCCalendar').removeClass('pCAct');
		var url = jQuery('#pCFind').data('url');

		jQuery.ajax({
			type: "POST",
			url: url,
			headers: {
				'Cache-Control': 'no-cache, no-store, must-revalidate',
				'Pragma': 'no-cache',
				'Expires': '0'
			},
			dataType: 'html',
			data: {
				start: jQuery('#pCCDatepicker').val(),
				sword: jQuery('#pCFind').val()
			},
			success: function (content) {
				jQuery('.pCList').html(content);
				updateSquareContainers();
			}
		});
	});

	if (jQuery('#pCCDatepicker').length > 0) {
		var months = new Array( "DEZ", "JÄN", "FEB", "MÄR", "APR", "MAI", "JUN", "JUL", "AUG", "SEP", "OKT", "NOV", "DEZ", "JÄN");
		var dateToday = new Date();
		var pCCDatepicker = jQuery("#pCCDatepicker").datepicker({
			minDate: dateToday,
			onSelect: function(selectedDate) {
				var url = jQuery('#pCFind').data('url');

				if (jQuery('.pCCalendar').attr('data-last') == selectedDate) {
					jQuery('.pCCalendar').attr('data-last','');
					jQuery('.pCCalendar').removeClass('pCAct');

					jQuery.ajax({
						type: "POST",
						url: url,
						headers: {
							'Cache-Control': 'no-cache, no-store, must-revalidate',
							'Pragma': 'no-cache',
							'Expires': '0'
						},
						dataType: 'html',
						data: {
							start: selectedDate,
							sword: jQuery('#pCFind').val()
						},
						success: function (content) {
							jQuery('.pCList').html(content);
							updateSquareContainers();
						}
					});
				} else {
					jQuery('.pCCalendar').attr('data-last',selectedDate);
					jQuery('.pCCalendar').addClass('pCAct');

					jQuery.ajax({
						type: "POST",
						url: url,
						headers: {
							'Cache-Control': 'no-cache, no-store, must-revalidate',
							'Pragma': 'no-cache',
							'Expires': '0'
						},
						dataType: 'html',
						data: {
							start: selectedDate,
							end: selectedDate,
							sword: jQuery('#pCFind').val()
						},
						success: function (content) {
							jQuery('.pCList').html(content);
							updateSquareContainers();
						}
					});
				}
			},
			beforeShowDay: function( date ) {
				var classCat1 = '';
				var classCat2 = '';

				jQuery('.pCCDates').each(function() {
					var dates = jQuery(this).attr('data-dates').split(',');
					var curDate = date.getDate()+'.'+(date.getMonth()+1)+'.'+date.getFullYear();
					var curClass = jQuery(this).attr('data-cat');

					jQuery(dates).each(function(i,x) {
						if (x == curDate) {
							if (curClass == 'calCat1') {
								classCat1 = 'calCat1';
							}
							if (curClass == 'calCat2') {
								classCat2 = 'calCat2';
							}
						}
					});
				});

				if (classCat1 && classCat2) {
					return [true, 'calDay '+classCat1+' '+classCat2, ''];
				} else if (classCat1) {
					return [true, 'calDay '+classCat1, ''];
				} else if (classCat2) {
					return [true, 'calDay '+classCat2, ''];
				} else {
					return [true, 'calDay', ''];
				}
			},
			onChangeMonthYear: function(year, month, datepicker) {
				var prevMonth = month - 1;
				var nextMonth = month + 1;
				var prevYear = year;
				var nextYear = year;

				if (prevMonth == 0) {
					prevYear -= 1;
				}
				if (nextMonth == 13) {
					nextYear += 1;
				}

				jQuery('.pCMPrev').html(months[parseInt(prevMonth)]+' '+prevYear);
				jQuery('.pCMNext').html(months[parseInt(nextMonth)]+' '+nextYear);
				jQuery('.pCCalendar').removeClass('pCAct');

				var url = jQuery('#pCFind').data('url');

				jQuery.ajax({
					type: "POST",
					url: url,
					headers: {
						'Cache-Control': 'no-cache, no-store, must-revalidate',
						'Pragma': 'no-cache',
						'Expires': '0'
					},
					dataType: 'html',
					data: {
						start: '01.'+month+'.'+year,
						sword: jQuery('#pCFind').val()
					},
					success: function (content) {
						jQuery('.pCList').html(content);
						updateSquareContainers();
					}
				});
			}
		});

		jQuery('.pCMPrev').on('click touch', function() {
			jQuery('#pCCDatepicker .ui-datepicker-prev').trigger('click');
		});

		jQuery('.pCMNext').on('click touch', function() {
			jQuery('#pCCDatepicker .ui-datepicker-next').trigger('click');
		});

		if (jQuery('.pCCStart').html()) {
			jQuery("#pCCDatepicker").datepicker().datepicker('setDate',jQuery('.pCCStart').html());
		}
	}

	jQuery('.dSPrint').on('click touch',function() {
		window.print();
	});
	jQuery('.contwiseHit').each(function() {
		var contwiseUid = jQuery(this).data('uid');
		jQuery.post( "/fileadmin/templates/scripts/contwiseHit.php", {
			uid: contwiseUid
		});
	});
	if (jQuery('.contwiseMapContainer').length > 0) {
		jQuery('.contwiseMapContainer').each(function() {
			var contwiseMap;
			var contwiseMapId = '#'+jQuery(this).attr('id');

			var mapLng = jQuery(this).data('maplng');
			var mapLat = jQuery(this).data('maplat');
			var mapZoom = jQuery(this).data('mapzoom');

			contwiseMap = new nefos.Page({
				mapContainer: contwiseMapId,
				disableHashHandling: true,
				view: new nefos.EmptyView(),
				requestHost: "https://tirol.mapservices.eu",
				requestBasePath: "nefos_app",
				systemName: "nefos_tirol",
				includeCSS: true
			});

			contwiseMap.addEventListener('initialisationComplete', function(){
				var topLeftLat = -90;
				var topLeftLng = -90;
				var bottomRightLat = 90;
				var bottomRightLng = 90;
				var contwiseMarker = [];
				var lastMarker;

				jQuery(contwiseMapId+'Pois .contwiseMapPoi').each(function(i,e) {
					var curLat = jQuery(this).data('lat');
					var curLng = jQuery(this).data('lng');
					var curName = jQuery(this).data('name');

					contwiseMarker.push(createContwiseMarker(window.location.protocol+"//"+window.location.host+"/fileadmin/templates/images/pin.png", curLat, curLng, curName));
					contwiseMarker[i].addEventListener("click", function() {
						if (lastMarker) {
							lastMarker.setIconImage(window.location.protocol+"//"+window.location.host+"/fileadmin/templates/images/pin.png");
						}
						contwiseMarker[i].setIconImage(window.location.protocol+"//"+window.location.host+"/fileadmin/templates/images/pinAct.png");

						jQuery('.contwiseMapPoi').hide();
						jQuery('.contwiseMapPoi'+i).show();

						$('html, body').animate({
							scrollTop: jQuery('.contwiseMapPoi'+i).offset().top-100
						}, 250);
						updateSquareContainers();

						lastMarker = contwiseMarker[i];
					});
					contwiseMap.addUserMapObject(contwiseMarker[i]);

					if (curLat > topLeftLat) {
						topLeftLat = curLat;
					}
					if (curLng > topLeftLng) {
						topLeftLng = curLng;
					}
					if (curLat < bottomRightLat) {
						bottomRightLat = curLat;
					}
					if (curLng < bottomRightLng) {
						bottomRightLng = curLng;
					}
				});

				var latDiff = topLeftLat - bottomRightLat;
				var lngDiff = topLeftLng - bottomRightLng;

				if (mapLng && mapLat) {
					setTimeout(function() {
						contwiseMap.setMapCenter(new nefos.LatLng(mapLat,mapLng));
					},500);
				} else {

					setTimeout(function() {
						contwiseMap.setMapCenter(new nefos.LatLng(topLeftLat-latDiff/2,topLeftLng-lngDiff/2));
					},500);
				}

				if (mapZoom) {
					contwiseMap.setMapZoomLevel(mapZoom);
				} else {
					if (window.innerWidth < 480) {
						contwiseMap.setMapZoomLevel(9);
					} else if (window.innerWidth < 1024) {
						contwiseMap.setMapZoomLevel(10);
					} else {
						contwiseMap.setMapZoomLevel(11);
					}
				}
			});
		});
	}

	if (jQuery('#cDMap').length > 0) {
		var script = document.createElement("script");
		script.onload = script.onreadystatechange = function() {
			nefos.utils.EmbedContent({
				id: "nefos-ui-embedWidget-"+jQuery('#cDMap').attr('data-origid'),
				src: "https://tirol.mapservices.eu/nefos_app/frontend/page/innsbruck/de/embed?id[0]="+jQuery('#cDMap').attr('data-origid')+"&panelType=detail&panelTitle=&renderScrollButtons=true&systemName=nefos_tirol&renderImages=false&requestProtocol=http:&requestHost=maps.innsbruck.info&mapType=gdi_summer&mapHeight=601",
				width: 1240,
				height: 600
			});
		};
		script.type = "text/javascript";
		script.src = "https://tirol.mapservices.eu/nefos_app/page/embed/embed.js";
		document.body.appendChild(script);
	}

	if (jQuery('.cDShare').length > 0) {
		jQuery('.cDShare').append(jQuery('#share'));
