	jQuery('.pluginNewsroom .load-more-items').on('click', function(){
		var cur = jQuery(this);
		var url = jQuery(this).data('url');
		var page = parseInt(jQuery(this).attr('data-page'));
		var format = 'html';

		jQuery.ajax({
			type: "POST",
			url: url,
			headers: {
				'Cache-Control': 'no-cache, no-store, must-revalidate',
				'Pragma': 'no-cache',
				'Expires': '0'
			},
			dataType: format,
			data: {
				page: page,
				sword: jQuery('#pNFind').val()
			},
			success: function (content) {
				jQuery('.pNList').append(content);
				cur.attr('data-page',parseInt(page+1));
			}
		});
	});
	jQuery('.cFClear').on('click touch', function() {
		jQuery('#resetForm').submit();
	});
	jQuery('.pluginNewsroom #pNFind').on('input', function(){
		var cur = jQuery('.pluginNewsroom .load-more-items');
		var url = jQuery('.pluginNewsroom .load-more-items').data('url');
		var format = 'html';

		delay(function(){
			jQuery.ajax({
				type: "POST",
				url: url,
				headers: {
					'Cache-Control': 'no-cache, no-store, must-revalidate',
					'Pragma': 'no-cache',
					'Expires': '0'
				},
				dataType: format,
				data: {
					page: 0,
					sword: jQuery('#pNFind').val()
				},
				success: function (content) {

					if (content == '') {
						jQuery('.pNList').html(jQuery('.pN404').html());
					} else {
						jQuery('.pNList').html(content);
					}
					cur.attr('data-page',1);
				}
			});
		}, 500);
	});

