		jQuery('.dceHeaderSmall .banner-wide').width(headerwidth);
    }
}

function updateLazyImage() {

	if (jQuery('.lazyImage').length > 0) {
		var curWidth = jQuery(window).width();
		var lazyImg = '';

        jQuery('.lazyImage').each(function() {
			lazyImg = jQuery(this).data('image');

			if ((curWidth < 480) && (jQuery(this).data('image-480'))) {
				lazyImg = jQuery(this).data('image-480');
			} else if ((curWidth < 768) && (jQuery(this).data('image-768'))) {
				lazyImg = jQuery(this).data('image-768');
			} else if ((curWidth < 1024) && (jQuery(this).data('image-1024'))) {
				lazyImg = jQuery(this).data('image-1024');
			} else if ((curWidth < 1300) && (jQuery(this).data('image-1300'))) {
				lazyImg = jQuery(this).data('image-1300');
			}
			if (jQuery(this).attr('src') != lazyImg) {
				jQuery(this).attr('src',lazyImg );
			}
        });
    }
}

function updateLazyBg() {
	if (jQuery('.lazyBackgroundImage').length > 0) {
		var curWidth = jQuery(window).width();
		var lazyImg = '';

        jQuery('.lazyBackgroundImage').each(function() {
			lazyImg = jQuery(this).attr('data-image');

			if ((curWidth < 480) && (jQuery(this).attr('data-image-480'))) {
				lazyImg = jQuery(this).attr('data-image-480');
			} else if ((curWidth < 768) && (jQuery(this).attr('data-image-768'))) {
				lazyImg = jQuery(this).attr('data-image-768');
			} else if ((curWidth < 1024) && (jQuery(this).attr('data-image-1024'))) {
				lazyImg = jQuery(this).attr('data-image-1024');
			} else if ((curWidth < 1300) && (jQuery(this).attr('data-image-1300'))) {
				lazyImg = jQuery(this).attr('data-image-1300');
			}

			if (jQuery(this).css('background-image') != 'url(' + lazyImg + ')') {
					jQuery(this).css('background-image', 'url(' + lazyImg + ')');
			}
        });
    }
}


function updateSquareContainers() {
	if (jQuery('.cDGallery').length > 0){
		if (jQuery(window).width() <= 640) {
			jQuery('.cDGallery .inner').width(jQuery(window).width()-40);
			jQuery('.cDGallery .inner').height(parseInt(jQuery(window).width()-40));
			jQuery('.contwiseDetail .cDGallery .likeH2, .contwiseDetail .cDGallery h2').css('margin-top','35%');
		} else if (jQuery(window).width() <= 1300) {
			jQuery('.cDGallery .inner').width(jQuery(window).width()-40);
			jQuery('.cDGallery .inner').height('640px');
			jQuery('.contwiseDetail .cDGallery .likeH2, .contwiseDetail .cDGallery h2').css('margin-top','320px');
		} else {
			jQuery('.cDGallery .inner').removeAttr('style');
			updateLazyBg()
		}
	}

	jQuery('.cLPIImage').each(function() {
		jQuery(this).height(Math.ceil(jQuery(this).width()));
	});

	if (jQuery(window).width() < 1024) {
		jQuery('.squareContainer').each(function() {
			jQuery(this).height(jQuery(this).width());
		});
	} else {
		jQuery('.squareContainer').each(function() {
			if (jQuery(this).hasClass('dTSIImage')) {
				jQuery(this).css('height','400px');
			} else {
				jQuery(this).css('height','auto');
			}
		});
	}
}

