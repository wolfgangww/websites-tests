        } else {
            if (jQuery('#mobileTrigger .open').length == 0) {
                jQuery('#quickNaviWrap').removeClass('hide');
                if (!jQuery('#topTargetFull').hasClass('act') && !jQuery('#topLangTarget').hasClass('act') && (parseInt(jQuery('#curPid').html()) == 1) && (parseInt(jQuery('#curPid').html()) == 5750)) {
