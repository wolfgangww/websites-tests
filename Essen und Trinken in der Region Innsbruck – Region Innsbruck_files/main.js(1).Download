function stickyNavi(force) {
    /*if (jQuery(window).width() < 1024) {*/
        st = $(this).scrollTop();
        if ((st > 0) || (force == 1)) {
			if (!jQuery('#top').hasClass('whiteBg')) {
				jQuery('#top').addClass('whiteBg');
				jQuery('#logo img').attr('src', jQuery('#logo img').data('red'));
