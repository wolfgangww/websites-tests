	jQuery('.dTMImage').on('click touch', function() {
		if (jQuery(window).width() < 1024) {
			jQuery(this).closest('.dceTeamslider').on('beforeChange', function(event, slick, currentSlide, nextSlide){
				jQuery('.dTMDescription').removeClass('act');
				jQuery('.dTMember').removeClass('act');
			});

			jQuery(this).next().toggleClass('act');
			jQuery(this).closest('.slick-list').css('height','auto');
			var newHeight = jQuery(this).height()+jQuery(this).next().height();
			jQuery(this).closest('.slick-list').css('height',newHeight);
		} else {
			var i = jQuery(this).closest('.dTMember').data('iterator');
			var curWidth = jQuery(this).closest('.slick-track').width();
			if (jQuery(this).closest('.dTMember').hasClass('act')) {
				jQuery(this).closest('.dceTeamslider').slick('slickGoTo', 0);
				/* https://jira.aquarius.digital/browse/IR-325 */
				jQuery(this).closest('.dceTeamslider').find('.dTMember').removeClass('act');
				jQuery(this).closest('.slick-track').width(curWidth - 660);
			} else {
				jQuery(this).closest('.dceTeamslider').slick('slickGoTo', i);
				jQuery(this).closest('.dceTeamslider').find('.dTMember').removeClass('act');
				jQuery(this).closest('.dTMember').addClass('act');
				jQuery(this).closest('.slick-track').width(curWidth + 660);
			}
		}
	});

