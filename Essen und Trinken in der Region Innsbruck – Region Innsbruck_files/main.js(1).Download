function startPolyCoords(cur, repeat) {
	if (cur.find('polygon').is('[data-from]') && cur.find('polygon').is('[data-to]')) {
		var fromPoints = cur.find('polygon').attr('data-from').split(' ');
		var toPoints = cur.find('polygon').attr('data-to').split(' ');
		var duration = parseInt(cur.find('polygon').attr('data-duration'));
		var steps = parseInt(duration / 16.6666666666) /* 60fps */

		for (i = 0; i <= steps; i++) {
			updatePolyCoords(cur.find('polygon'), i, fromPoints, toPoints, duration, steps);
		}

		cur.find('polygon').attr('data-to', fromPoints.join(' '));
		cur.find('polygon').attr('data-from', toPoints.join(' '));

		if (repeat > 0) {
			setTimeout(function() {
				startPolyCoords(cur, 1);
			}, duration);
		}
	}
}

function updatePolyCoords(cur, i, fromPoints, toPoints, duration, steps) {
    setTimeout(function() {
        var newPoints = [];

        jQuery(fromPoints).each(function(j, e) {
            fromCoords = e.split(',');
            toCoords = toPoints[j].split(',');
            var newCoords = [];

            if (fromCoords[0] > toCoords[0]) {
                diffX = fromCoords[0] - toCoords[0];
            } else {
                diffX = toCoords[0] - fromCoords[0];
            }

            if (fromCoords[1] > toCoords[1]) {
                diffY = fromCoords[1] - toCoords[1];
            } else {
                diffY = toCoords[1] - fromCoords[1];
            }

            stepX = diffX / steps;
            stepY = diffY / steps;

            if (fromCoords[0] > toCoords[0]) {
                newCoords.push(parseInt(fromCoords[0]) - parseInt(stepX * i));
            } else {
                newCoords.push(parseInt(fromCoords[0]) + parseInt(stepX * i));
            }

            if (fromCoords[1] > toCoords[1]) {
                newCoords.push(parseInt(fromCoords[1]) - parseInt(stepY * i));
            } else {
                newCoords.push(parseInt(fromCoords[1]) + parseInt(stepY * i));
            }

            newPoints.push(newCoords.join(','));
        });

        cur.attr('points', newPoints.join(' '));
    }, parseInt(i * 16.6666666666));
}

