    jQuery('.dceZitatInner').on('afterChange', function(event, slick, currentSlide) {
    	svgHeight();
        var zitatSvg = jQuery('.slick-active .zitatSvg').attr('data-image');
        updateClipPathPoly(jQuery('.zitatSvgWrap svg'), 60);
        jQuery(this).next().find('.dTSIImageInner').attr('data-image', zitatSvg);
        jQuery(this).next().find('.dTSIImageInner').css('background-image', 'url(' + zitatSvg + ')')
        jQuery('.svgFade').addClass('active');
        setTimeout(function() {
            jQuery('.zitatSvgWrap .dTSIImage').attr('data-image', zitatSvg);
            jQuery('.zitatSvgWrap .dTSIImage').css('background-image', 'url(' + zitatSvg + ')')
            jQuery('.zitatSvgWrap .dTSIImageInner').removeAttr('data-image');
            jQuery(".zitatSvgWrap .dTSIImageInner").removeAttr("style");
            jQuery('.svgFade').removeClass('active');
         }, 500);
         if (jQuery(window).width() < 570) {
            var polyWidth = jQuery('.zitatSvgWrap svg').width();
			var ratio = polyWidth / 530;
			jQuery('.zitatSvgWrap svg polygon').attr('data-to', getRandomArbitrary(0, parseInt(ratio * 45)) + ',' + getRandomArbitrary(0, parseInt(ratio * 145)) + ' ' + getRandomArbitrary(parseInt(ratio * 420), parseInt(ratio * 530)) + ',' + getRandomArbitrary(0, parseInt(ratio * 45)) + ' ' + parseInt(ratio * 530) + ',' + getRandomArbitrary(parseInt(ratio * 320), parseInt(ratio * 456)) + ' ' + getRandomArbitrary(0, parseInt(ratio * 235)) + ',' + parseInt(ratio * 456));
         } else {

         }
         startPolyCoords(jQuery('.zitatSvgWrap svg'), 0);
     });
