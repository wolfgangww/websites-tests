                jQuery('#quickNaviWrap').removeClass('hide');
                if (!jQuery('#topTargetFull').hasClass('act') && !jQuery('#topLangTarget').hasClass('act') && !jQuery('#mainNavi > ul > li').hasClass('act') && (parseInt(jQuery('#curPid').html()) == 1)) {
                    jQuery('#top').removeClass('whiteBg');
                    jQuery('#logo img').attr('src', jQuery('#logo img').data('white'));
