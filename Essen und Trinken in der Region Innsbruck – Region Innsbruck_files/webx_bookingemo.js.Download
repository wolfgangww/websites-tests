		jQuery(this).parents().find(".glyphicon-chevron-up").removeClass("glyphicon-chevron-up").addClass("glyphicon-chevron-down");
		if (jQuery(this).hasClass("active")) {
			jQuery(this).parents().find('.active').removeClass("active");
		} else {
			jQuery(this).next().slideToggle();
			jQuery(this).addClass("active");
			jQuery(this).find("span").removeClass("glyphicon-chevron-down").addClass("glyphicon-chevron-up");
		}

	});
	
