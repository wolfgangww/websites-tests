jQuery(".tx-webx-bookingemo .singleView .tabs .tab").click(function(){
    jQuery(".tx-webx-bookingemo .singleView .tabs .tab").removeClass("current");
    jQuery(this).addClass("current");

    if(jQuery(this).hasClass("initGoogleMaps")) {
        initialize();
        if (navigator.geolocation)
            navigator.geolocation.getCurrentPosition(setUserGeoLoation);
        jQuery(this).removeClass("initGoogleMaps");
    }
    if(jQuery(this).hasClass('initgsMaps')) {
        if( obj != undefined) 
            map = new Map('#mapWEBX',obj);
        else map = new Map();
    }


    jQuery(".tx-webx-bookingemo .singleView .emotabContents .emotabContent").removeClass("current");
    var id = jQuery(this).data("tab");
    jQuery("#" + id).addClass("current");
});


function Enquery_PAvailableFrom(date) {

	if (date < new Date) {
		return [false, "", "unAvailable"];
	}

	dmy = date.getFullYear() + "-" + ("0" + (date.getMonth() + 1)).slice(-2) + "-" + ("0" + date.getDate()).slice(-2);
	if (jQuery.inArray(dmy, package_arrivaldays2) != -1) {
		return [true, "", "Available"];
	} else {
		return [false, "", "unAvailable"];
	}
}


function Enquery_addDays(date, days) {
	dateString = date.match(/^(\d{2})\.(\d{2})\.(\d{4})$/);
	result = new Date(dateString[3], dateString[2] - 1, dateString[1]);

	result.setDate(result.getDate() + parseInt(days) - 1);
	return result;
}


function Enquery_Pmdate() {
   	dateString = package_arrivaldays2[0].match(/^(\d{4})\-(\d{2})\-(\d{2})$/);
	return new Date( dateString[1], dateString[2]-1, dateString[3]);
}

function sendEnquiry() {
	swal({
		title: "Anfrage wird gesendet",
		text: "<img src='/typo3conf/ext/webx_bookingemo/Resources/Public/Images/ajax-loader_2.gif' /><style>.sweet-alert  .confirm { display:none; }</style>",
		showConfirmButton: false,
		html: true ,
		type: "info"
	});
	xajax_ajaxDoEnquiry(jQuery("#newEnquiry").serialize());


}

function sendEnquiry_cb(r) {
	json = JSON.parse(r);
	if(json.status == "success") {
		swal({
				title: "Anfrage wurde gesendet",
				text: "",
				type: "success",
				confirmButtonText: "Zur Startseite >>"
			},
			function (isConfirm) {
				if (isConfirm) {
					document.location.href = "";
				}
			}
		);
	} else if(json.status == "error")
		swal({
			title: "Leider ist ein Fehler passiert!",
			text: "Fehler: " + json.errorMessage,
			type: "error",
			confirmButtonText: "Daten bearbeiten"
		});
}

jQuery(document).ready(function() {
	var mobile = (/android|webos|iphone|ipad|ipod|blackberry|iemobile|opera mini/i.test(navigator.userAgent.toLowerCase()));


	// show filters
	jQuery('.tx-webx-bookingemo .fTToggle.tFShow').trigger("click");


	/* package enquiry */
	if (typeof packageDuration == 'object') {
		// create new select box
		var select = '<select name="tx_webxbookingemo_main[newEnquiry][selNights]" class="form-style selNights" required="required"><option>' + jQuery('#newEnquiry').data('nights') + '</option></select>';
		jQuery(".datepickerTo").parent().html(select);


		// create event listener
		jQuery(".datepickerFromEnquiry").change(function(e) {

			var valHtml = "";

			pickedDate = jQuery.datepicker.formatDate("yy-mm-dd", jQuery(this).datepicker('getDate'));

			jQuery.each(packageDuration[pickedDate], function(e) {
				 e = e - 1;
				if (e == 1) {
					valHtml += '<option value="' + e + '">' + e + ' '+ jQuery('#newEnquiry').data('night') +'</option>';
				} else {
					valHtml += '<option value="' + e + '">' + e + ' '+ jQuery('#newEnquiry').data('nights') +'</option>';
				}
			});

			jQuery(".selNights").html(valHtml);
		});


		delete package_arrivaldays2;

	}

	if (typeof package_arrivaldays2 == 'object') {


		jQuery('.datepickerFromEnquiry').datepicker({
			beforeShowDay: Enquery_PAvailableFrom,
			dateFormat: 'dd.mm.yy',
			minDate: Enquery_Pmdate(),
			onClose: function (selectedDate) {
				if (selectedDate) {
					jQuery(".datepickerTo").datepicker("option", "minDate", selectedDate);
					jQuery(".datepickerTo").datepicker("option", "disabled", true);
					jQuery(".datepickerTo").datepicker("setDate", Enquery_addDays(selectedDate, package_duration));
				}
			}
		});


		jQuery(".datepickerTo").datepicker({
			dateFormat: 'dd.mm.yy',
			disabled: true
		});

	} else {

		jQuery('.datepickerFromEnquiry').datepicker({
			dateFormat: 'dd.mm.yy',
			minDate: "+1d",
			onClose: function (selectedDate) {
				if (selectedDate) {
					jQuery(".datepickerTo").datepicker("option", "minDate", selectedDate);
				}
			}
		});


		jQuery(".datepickerTo").datepicker({
			dateFormat: 'dd.mm.yy',
			onClose: function (selectedDate) {
				if (selectedDate) {
					jQuery(".datepickerFromEnquiry").datepicker("option", "maxDate", selectedDate);
				}
			}

		});


	}


	/* END enquiry */


