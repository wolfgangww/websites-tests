function updateCalculation(){let cur=Cookies.get('cardCat').split(',');let adults=jQuery('#cardCalcAdults').val();let kids=0;let priceWithoutCard=0;let priceWithCard=0;for(let i=1;i<6;i++){if(jQuery('#cardCalcAgeChild'+i).val()>5){kids++}}
jQuery(cur).each(function(i,e){priceWithoutCard+=parseFloat(jQuery('.pCCBox[data-place="'+e+'"]').data('price-adult-no-card'))*adults+parseFloat(jQuery('.pCCBox[data-place="'+e+'"]').data('price-kid-no-card'))*kids;priceWithCard+=parseFloat(jQuery('.pCCBox[data-place="'+e+'"]').data('price-adult-with-card'))*adults+parseFloat(jQuery('.pCCBox[data-place="'+e+'"]').data('price-kid-with-card'))*kids});let pricePublicTransport=parseFloat(jQuery('#pCCPublicTransport').data('daily-public-transport')/24*jQuery('.pCCCard.act').data('card')*adults)+parseFloat(jQuery('#pCCPublicTransport').data('daily-public-transport-kids')/24*jQuery('.pCCCard.act').data('card')*kids);let priceTotalWithoutCard=priceWithoutCard+pricePublicTransport;jQuery('#publicTransportDuration').html(jQuery('.pCCCard.act').data('card'));let priceCard=parseFloat(jQuery('.pCCCard.act').data('price')*adults)+parseFloat(jQuery('.pCCCard.act').data('price-kids')*kids);let priceTotalWithCard=priceWithCard+priceCard;jQuery('#priceWithoutCard').html(priceWithoutCard.toFixed(2));jQuery('#pricePublicTransport').html(pricePublicTransport.toFixed(2));jQuery('#priceWithCard').html(priceTotalWithCard.toFixed(2));let priceSaved=priceTotalWithoutCard-priceTotalWithCard;if(priceSaved<0){priceSaved=0}
jQuery('#priceSaved').html(priceSaved.toFixed(2))}
