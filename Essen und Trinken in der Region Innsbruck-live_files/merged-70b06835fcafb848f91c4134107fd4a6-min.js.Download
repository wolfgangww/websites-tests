function createContwiseMarker(icon,lat,lng,name){var marker=new nefos.Marker({name:name,position:new nefos.LatLng(lat,lng),icon:{image:icon,width:34,height:43,anchor:{x:0,y:43},},zIndex:10000,clusterable:!1,hoverable:!1,dragable:!1,clickable:!0});return marker}
function getRandomArbitrary(min,max){return parseInt(Math.random()*(max-min)+min)}
