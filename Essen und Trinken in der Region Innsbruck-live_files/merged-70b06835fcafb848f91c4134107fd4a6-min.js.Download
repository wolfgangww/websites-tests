function parallaxFullScreenUpdate(){setTimeout(function(){var targetBeginPos=parseInt(jQuery('.dFPSIFixed').offset().top-parseInt(jQuery(window).height()/2)+parseInt(jQuery('.dFPSIFixed').height()/2));var targetEndPos=parseInt(jQuery('.dFPSAnchor > div').offset().top)-parseInt(jQuery(window).height()/2);jQuery(window).scroll(function(){if(jQuery(window).scrollTop()>=targetBeginPos){if(jQuery(window).scrollTop()<=targetEndPos){if(!jQuery('.dFPSIFixed').hasClass('act')){jQuery('.dFPSIFixed').addClass('act');jQuery('.dFPSIFixed').css('top',(parseInt(jQuery(window).height()/2)-parseInt(jQuery('.dFPSIFixed').height()/2))-100)}}else{if(jQuery('.dFPSIFixed').hasClass('act')){jQuery('.dFPSIFixed').removeClass('act');jQuery('.dFPSIFixed').css('top',(parseInt(targetEndPos)+parseInt(jQuery(window).height()/2)-parseInt(jQuery('.dFPSIFixed').height()/2)-100));jQuery('.dFPSIFixed').css('position','absolute')}}}else{if(jQuery('.dFPSIFixed').hasClass('act')){jQuery('.dFPSIFixed').removeClass('act');jQuery('.dFPSIFixed').css('position','relative');jQuery('.dFPSIFixed').css('top','auto')}}});var targetBeginPos=parseInt(jQuery('.dFPSNFixed').offset().top-parseInt(jQuery(window).height()/2)+parseInt(jQuery('.dFPSNFixed').height()/2));var targetEndPos=parseInt(jQuery('.dFPSAnchor > div').offset().top)-parseInt(jQuery(window).height()/2);jQuery(window).scroll(function(){if(jQuery(window).scrollTop()>=targetBeginPos){if(jQuery(window).scrollTop()<=targetEndPos){if(!jQuery('.dFPSNFixed').hasClass('act')){jQuery('.dFPSNFixed').addClass('act');jQuery('.dFPSNFixed').css('top',(parseInt(jQuery(window).height()/2)-parseInt(jQuery('.dFPSNFixed').height()/2))+60)}}else{if(jQuery('.dFPSNFixed').hasClass('act')){jQuery('.dFPSNFixed').removeClass('act');jQuery('.dFPSNFixed').css('top',(parseInt(targetEndPos)+parseInt(jQuery(window).height()/2)-parseInt(jQuery('.dFPSIFixed').height()/2)));jQuery('.dFPSNFixed').css('position','absolute')}}}else{if(jQuery('.dFPSNFixed').hasClass('act')){jQuery('.dFPSNFixed').removeClass('act');jQuery('.dFPSNFixed').removeAttr('style')}}});jQuery(window).scroll(function(){var targetBeginPos=parseInt(jQuery('.dceFactsParallax').offset().top-jQuery('.dFPScreen:first-of-type').height());var curPos=jQuery(window).scrollTop();var screenHeight=jQuery(window).height();var screenNumber=1;if((curPos-targetBeginPos)>0){var screenNumber=Math.ceil(((curPos-targetBeginPos-(screenHeight/2))/screenHeight));if(screenNumber>jQuery('.dFPScreen').length){screenNumber=jQuery('.dFPScreen').length}
if(screenNumber<1){screenNumber=1}
if(!jQuery('.dFPSNFixed span:nth-of-type('+screenNumber+')').hasClass('act')){jQuery('.dFPSNFixed span.act').removeClass('act');jQuery('.dFPSNFixed span:nth-of-type('+screenNumber+')').addClass('act');var newImg=jQuery('.dFPScreen:nth-of-type('+screenNumber+')').attr('data-image');jQuery('.dFPSIImage').attr('style','background-image: url('+newImg+')');if((GetIEVersion()>0)&&(GetIEVersion()<12)){jQuery('.dFPSIFixed').css('background-image','url('+newImg+')')}
updateClipPathPoly(jQuery('.dFPSImage svg'),parseInt(jQuery(window).width()/20))}}else{jQuery('.dFPSNFixed span.act').removeClass('act')}})},2000)}
function getHashFromUrl(url){return jQuery("<a />").attr("href",url)[0].hash.replace(/^#/,"")}
function changeDetailTeaserSizes(){var cDataEnd=jQuery('.cDData').offset().top+jQuery('.cDData').outerHeight();var teaserStart=jQuery('.cDDCTeaser').eq(0).offset().top;if(teaserStart>cDataEnd){jQuery('.cDDCTeaser').each(function(i,e){var cur=jQuery(this);switch(i){case 2:case 7:case 13:cur.removeClass("cDDCT-3-12").addClass("cDDCT-6-12");break}
switch(i){case 10:cur.removeClass("cDDCT-3-12").addClass("cDDCT-12-12");break}
switch(i){case 2:case 6:case 9:case 10:case 13:cur.css('margin-right',0);break}
if((i>13)&&((i-1)%4==0)){cur.css('margin-right',0)}})}else{var last=0;jQuery('.cDDCTeaser').each(function(i,e){var cur=jQuery(this);switch(i){case 2:case 7:case 13:cur.removeClass("cDDCT-3-12").addClass("cDDCT-6-12");break}
switch(i){case 10:cur.removeClass("cDDCT-3-12").addClass("cDDCT-12-12");break}
switch(i){case 10:cur.removeClass("cDDCT-3-12").addClass("cDDCT-12-12");break}
if((last>0)&&(last!=cur.offset().top)&&((cur.offset().top-last)<330)){cur.before('<div style="clear: both;"></div>');jQuery('.cDDCTeaser').eq(i-1).css('margin-right',0)}else{if((last>0)&&(last!=cur.offset().top)&&((cur.offset().top-last)>=330)){var beforeOffset=cur.offset().top;cur.css('margin-right',0);if(beforeOffset==cur.offset().top){cur.css('margin-right','20px')}}}
last=cur.offset().top})}}
function getURLParameter(sParam){var sPageURL=window.location.search.substring(1);var sURLVariables=sPageURL.split('&');for(var i=0;i<sURLVariables.length;i++){var sParameterName=sURLVariables[i].split('=');if(sParameterName[0]==sParam){return sParameterName[1]}}}
function inArray(needle,haystack){var length=haystack.length;for(var i=0;i<length;i++){if(typeof haystack[i]=='object'){if(arrayCompare(haystack[i],needle))return!0}else{if(haystack[i]==needle)return!0}}
return!1}
window.addEventListener("orientationchange",function(){updateHeaderVideo()},!1);var player;var headerVideoId='headerVideo';function GetIEVersion(){var sAgent=window.navigator.userAgent;var Idx=sAgent.indexOf("MSIE");if(Idx>0)
return parseInt(sAgent.substring(Idx+5,sAgent.indexOf(".",Idx)));else if(!!navigator.userAgent.match(/Trident\/7\./))
return 11;else return 0}
function updateHeaderVideo(){if(jQuery('#headerVideo').length>0){if(player){player.stopVideo();player.destroy();player=null}
setTimeout(function(){if((jQuery(window).height()/jQuery(window).width())<=0.5625){var yTHeight=parseInt(jQuery(window).width()*0.5625)+1;var yTWidth=jQuery(window).width()+1}else{var yTHeight=jQuery(window).height()+1;var yTWidth=parseInt(jQuery(window).height()*(1/0.5625))+1}
player=new YT.Player(headerVideoId,{height:yTHeight,width:yTWidth,videoId:jQuery('#headerVideo').parent().data('youtubehash'),playerVars:{rel:0,showinfo:0,loop:1,autoplay:1,controls:0},events:{'onReady':startYtPlay,'onStateChange':onPlayerStateChange}});function startYtPlay(event){event.target.mute();event.target.setVolume(0);event.target.playVideo()}
function onPlayerStateChange(event){if((event.data===0)||(event.data===2)){player.seekTo(0)}}},500)}}
function availableFunction(date){availday=date.getDate()+"-"+(date.getMonth()+1)+"-"+date.getFullYear();if(jQuery.inArray(availday,availableDates)>-1){return[!0,"eventday",""]}else{return[!0,"other",""]}}
