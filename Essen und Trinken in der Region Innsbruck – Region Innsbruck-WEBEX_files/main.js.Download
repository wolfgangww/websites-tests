$(document).ready(function () {
	var wrapper = $('.tx-webx-bing-search');
	var search_form = wrapper.find('.bing_search_form');
	var search_bar = search_form.find('.bing_search_bar');
	var bing_speak = wrapper.find('.bing_speak');
	var bing_speak_microphone = bing_speak.find('.fa-microphone');
	var working = false;

	if (wrapper.length > 0) {
		// load fancybox if not included
		if (typeof $.fn.fancybox === 'undefined') {
			$('head').append('<link rel="stylesheet" type="text/css" href="/typo3conf/ext/webx_bing_search/Resources/Public/vendor/fancybox-master/dist/jquery.fancybox.min.css" media="all">');
			$('body').append('<script src="/typo3conf/ext/webx_bing_search/Resources/Public/vendor/fancybox-master/dist/jquery.fancybox.min.js" type="text/javascript"></script>');
		}

		// initially trigger the search for pre-filled search bar
		bingSearch(0);

		search_form.submit(function (e) {
			e.preventDefault();

			// remove focus of input
			search_bar.blur();

			// trigger the search
			bingSearch(0);
		});

		// remove microphone if browser doesn't support MediaStream Recording API
		if (!navigator.mediaDevices) {
			search_form.find('.fa-microphone').remove();
		}

		search_form.find('.fa-microphone').click(function () {
			var constraints = {audio: true};
			var chunks = [];
			bing_speak.addClass('recording');

			navigator.mediaDevices.getUserMedia(constraints)
				.then(function(stream) {
					var audioContext = new AudioContext();
					var input = audioContext.createMediaStreamSource(stream);
					var analyser = audioContext.createAnalyser();
					var scriptProcessor = audioContext.createScriptProcessor();
					var mediaRecorder = new MediaRecorder(stream);
					var wait = false;
					chunks = [];

					// configure analyzer
					analyser.smoothingTimeConstant = 0.01;
					analyser.fftSize = 2048;
					analyser.minDecibels = -100;
					analyser.maxDecibels = -10;

					// connect audio chain
					input.connect(analyser);
					analyser.connect(scriptProcessor);
					scriptProcessor.connect(audioContext.destination);

					// start recording
					mediaRecorder.start();

					// stop recording after 14s because bing rest api doesn't support more
					setTimeout(function () {
						if (mediaRecorder.state == 'recording') {
							mediaRecorder.stop();
						}
						if (audioContext.state == 'running') {
							audioContext.close();
						}
					}, 14000);

					// append audio chunks to array
					mediaRecorder.ondataavailable = function(e) {
						chunks.push(e.data);
					};

					mediaRecorder.onstop = function(e) {
						var blob = new Blob(chunks, {'type': 'audio/wav; codec=audio/pcm; samplerate=16000'});
						var formData = new FormData();
						formData.append('data', blob);

						// send recorded audio to server for further processing
						$.ajax({
							method: 'post',
							url: search_form.attr('action'),
							data: formData,
							contentType: false,
							processData: false
						}).done(function (data) {
							// assign converted recording
							search_bar.val(data);

							// trigger the search
							bingSearch(0);

							// hide recording wizard
							bing_speak.removeClass('recording');
						});
					};

					// process recorded audio in real time
					scriptProcessor.onaudioprocess = function (audioProcessingEvent) {
						var frequencyData = new Uint8Array(analyser.frequencyBinCount);
						analyser.getByteFrequencyData(frequencyData);

						// add class to change the color of the microphone
						bing_speak_microphone.addClass('speak');

						// after average timeout remove the class
						// a css transition takes care of color fading
						if (!wait) {
							wait = true;
							setTimeout(function () {
								bing_speak_microphone.removeClass('speak');
								wait = false;
							}, getAverageVolume(frequencyData) * 3);
						}
					};

					// stop recording if microphone is clicked
					bing_speak.find('.fa-microphone').one('click', function () {
						mediaRecorder.stop();
						audioContext.close();
					});
				})
				.catch(function(err) {
					console.log('The following error occurred: ' + err);
				})
		});

		// change search categories
		wrapper.find('.bing_navigation div').click(function () {
			wrapper.find('.bing_navigation div').removeClass('current');
			$(this).addClass('current');
			search_form.attr('action', $(this).data('formAction')).trigger('submit');
		});
	}

	// generic search function
	function bingSearch(page) {
		if (!working && search_bar.val() != '') {
			// prevent duplicate execution
			working = true;

			// display spinner
			wrapper.preloader();

			// set page count of hidden input
			search_form.find('input[name*="page"]').val(page);

			$.ajax({
				method: 'get',
				url: search_form.attr('action'),
				data: search_form.serialize(),
				dataType: 'json'
			}).then(function (data) {
				// hide spinner
				wrapper.preloader('remove');

				// assign search results
				wrapper.find('.bing_results').html(data.results);

				// show search categories
				wrapper.find('.bing_navigation').show();

				// hide pagination if estimated_results are null
				if (data.estimated_results == null) {
					search_form.find('.estimated_results').hide();
					wrapper.find('.bing_pagination .pages').hide();
					working = false;
				} else {
					// show estimated_results below search_bar
					search_form.find('.estimated_results').show();
					search_form.find('.estimated_results .estimated').text(data.estimated_results);

					// show pagination
					wrapper.find('.bing_pagination .pages').show();
					makePaging(data.estimated_results, page, function () {
						working = false;
					});

					// wait for all images are loaded to get correct bounding, then instantiate masonry plugin
					wrapper.find('.bing_results .images').waitForImages(function() {
						$(this).masonry({
							itemSelector: '.bing_result',
							gutter: 20
						});
					});

					// instantiate fancybox plugin
					wrapper.find('.bing_results .images [data-fancybox]').fancybox({
						loop: true,
						buttons : [
							'zoom',
							'close'
						]
					});

					// instantiate masonry plugin for video thumbnails
					wrapper.find('.bing_results .videos').masonry({
						itemSelector: '.bing_result',
						gutter: 20
					});

					// play preview on hover of video thumbnail
					wrapper.find('.bing_results .videos .bing_result').each(function () {
						var video = $(this).find('video');
						var thumbnail = $(this).find('.preview');

						if (video.length > 0) {
							thumbnail.hover(function () {
								thumbnail.css('background', 'black');
								video.show().get(0).play();
							}, function () {
								thumbnail.css('background', 'url(' + thumbnail.data('thumbnail') + ') center');
								thumbnail.css('background-size', 'cover');
								video.hide().get(0).pause();
							});
						}
					});
				}
			});
		}
	}

	function makePaging(results, page, callback) {
		var pager = wrapper.find('.bing_pagination .pages').paging(results, {
			format: '<nnnnncnnnn>',
			perpage: search_form.data('resultsPerPage'),
			lapping: 0,
			page: 1,
			onSelect: bingSearch,
			onFormat: function (type) {
				switch (type) {
					case 'block':
						if (!this.active) {
							return '<a href="#" class="disabled">' + this.value + '</a>';
						} else if (this.value != this.page) {
							return '<a href="#">' + this.value + '</a>';
						}
						return '<a href="#" class="current">' + this.value + '</a>';
					case 'next':
						return '<a href="#" class="next"></a>';
					case 'prev':
						return '<a href="#" class="previous"></a>';
				}
			}
		});
		pager.setPage(page);

		// paging plugin is async
		// make callback to prevent duplicate execution because working is already false at this moment
		callback();
	}

	function getAverageVolume(array) {
		var length = array.length;
		var values = 0;
		var i = 0;

		for (; i < length; i++) {
			values += array[i];
		}

		return values / length;
	}
});