function svgWidth() {
    var svgWidth = jQuery('.dceZitatInner').width();
    jQuery('.zitatSvgWrap').width(svgWidth);
}


function mapWidthMob() {
    var width = jQuery('.dTMMap.mob img').width();
    var height = jQuery('.dTMMap.mob img').height();
    jQuery('.dTMMap.mob .dTMMPWPin').each(function() {
        var top = jQuery(this).data('top');
        var left = jQuery(this).data('left');
        var sumHeight = height * (parseInt(top) / 100)
        var sumWidth = width * (parseInt(left) / 100)
        var finalTop = jQuery(this).css('top', parseInt(sumHeight) + 'px');
        var finalLeft = jQuery(this).css('left', parseInt(sumWidth) + 'px');
    });

}

function mapWidthDesktop() {
    var width = jQuery('.dTMMap.desktop img').width();
    var height = jQuery('.dTMMap.desktop img').height();

    // jQuery('.dTMMap.desktop').width(width)
    jQuery('.dTMMap.desktop .dTMMPWPin').each(function() {
        var top = jQuery(this).data('top');
        var left = jQuery(this).data('left');
        var sumHeight = height * (parseInt(top) / 100)
        var sumWidth = width * (parseInt(left) / 100)
        var finalTop = jQuery(this).css('top', parseInt(sumHeight) + 'px');
        var finalLeft = jQuery(this).css('left', parseInt(sumWidth) + 'px');
    });

}

function updateEscapeContentNew() {

    if (jQuery(window).width() > 1300) {
        var negMargin = '+' + Math.ceil((jQuery(window).width() - 1300) / 2);
        jQuery('.tooltipster-fade').css('margin-left', negMargin + 'px');
    } else {
        jQuery('.tooltipster-fade').removeAttr('style');
    }
}

function cssGrid() {
    if (jQuery('.grid').length > 0) {
        jQuery('.grid__item, .grid__description').unwrap();
    }
    jQuery('.dceTeamCat').each(function() {
        var divs = $(this).find(".dceTeammodul > div");

        if ($(window).width() < 769) {
            for (var i = 0; i < divs.length; i += 2) {
                divs.slice(i, i + 2).wrapAll("<div class='grid'></div>");
            }
        } else if ($(window).width() < 1025) {
            for (var i = 0; i < divs.length; i += 4) {
                divs.slice(i, i + 4).wrapAll("<div class='grid'></div>");
            }
        } else if ($(window).width() < 1375) {
            for (var i = 0; i < divs.length; i += 6) {
                divs.slice(i, i + 6).wrapAll("<div class='grid'></div>");

            }
        } else {
            for (var i = 0; i < divs.length; i += 8) {
                divs.slice(i, i + 8).wrapAll("<div class='grid'></div>");
            }
        }
    });

}

