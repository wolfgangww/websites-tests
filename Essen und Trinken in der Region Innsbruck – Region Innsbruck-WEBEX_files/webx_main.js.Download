function ajaxCallbackInfrastructureFilter(count) {
    console.log("dope");
    jQuery(".tx-webx-bookingemo .updateNumber").html(count);
    // jQuery(".tx-webx-bookingemo .updateNumber." + selectorId.replace('#','')).html(formatNumber(count));
    jQuery(".tx-webx-bookingemo .loader").slideUp("fast");
