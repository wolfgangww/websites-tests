    jQuery('#trustYouLink').click( function() {
        var w = window.open(jQuery('#trustYouLink').data('url'), "popupWindow", jQuery('#trustYouLink').data('style'));
    });

    /* filter preselect */
    args = decodeURIComponent(location.search.slice(1)).split('&');
    if (!Array.isArray(args)) args = [args];
    /*console.log("doep");*/
    for ( i in args ) {
        if (args[i].includes("filter=")) {
            ids = args[i].replace("filter=","").split(",");
            if ( jQuery(".tx-webx-bookingemo .filterView form").length > 0 ) {
                jQuery.each(ids, function(a,i) {
                    if(jQuery(".tx-webx-bookingemo input[name^='tx_webxbookingemo'][value='" + i +"']").length > 0 )  {
                        jQuery(".tx-webx-bookingemo input[name^='tx_webxbookingemo'][value='" + i +"']").prop('checked', true);
                        // jQuery("#filterBookingemoHidden").remove();
                    } else if( jQuery("#filterBookingemoHidden"+i).length > 0 ) {
                        jQuery("#filterBookingemoHidden"+i).val(i);
                    } else {
                        jQuery(".tx-webx-bookingemo .filterView form").append('<input type="hidden" name="' + jQuery(jQuery(".tx-webx-bookingemo input[name^='tx_webxbookingemo']")[0]).attr('name').replace(/([a-zA-Z_]*)(?:.*)/gi,'$1') + '[filterHidden][]" value="' + i + '" />');
                    }

                });
                jQuery.each(ids, function(a,i) {
                    jQuery(".tx-webx-bookingemo option[value='" + i +"']").prop('selected', true);
                });
                jQuery('.tx-webx-bookingemo select.chosen-multiselect').trigger("chosen:updated");
                jQuery('.tx-webx-bookingemo .filterView form').trigger("submit");
            } else {
                if ( jQuery(".emoback.dceButton.normal a.emoButton.pull-left,.backToList.dceButton.normal a.emoButton.pull-left").length > 0 ) {
                    jQuery(".emoback.dceButton.normal a.emoButton.pull-left,.backToList.dceButton.normal a.emoButton.pull-left").each( function() {
                        $(this).attr("href",$(this).attr('href')+'?filter='+ids.join(','));
                    });
                }
            }

        }
    }


