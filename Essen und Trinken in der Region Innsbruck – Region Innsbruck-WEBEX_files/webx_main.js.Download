/* checkout */
function submitCheckoutForm() {
    // check form is validated by h5validator
    if (jQuery("#payment-form").h5Validate('allValid') == false) {
        return false;
    }

    //check creditcard
    var ccIdentifier = jQuery(".card-wrapper .card").prop("class").replace("card","").replace("identified","").replace("safari","").replace("ie-11","").replace("flipped","").trim();
    if(jQuery("#paymentmethod option[data-indentifier=" + ccIdentifier + "]").length == 0) {
        swal({
            title: "Kreditkarte wird nicht leider unterstützt!",
            type: "error"
        });
        return false;
    } else {
        jQuery("#paymentmethod").val(jQuery("#paymentmethod option[data-indentifier=" + ccIdentifier + "]").prop("value"));
        swal({
            title: "Bearbeite Bezahlung!",
