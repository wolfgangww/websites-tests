jQuery(".tx-webx-bookingemo .reset").click( function(e) {
    // console.log("CLICKED");
    if(jQuery(".tx-webx-bookingemo .eventFilterView form").length> 0 )
        itms = jQuery(".tx-webx-bookingemo .eventFilterView form ." + $(this).data('cat') ).find(':' + $(this).data('itm'));
    else if (jQuery(".tx-webx-bookingemo .infrastructureFilterView form").length > 0)
        itms = jQuery(".tx-webx-bookingemo .infrastructureFilterView form ." + $(this).data('cat') ).find(':' + $(this).data('itm'));
    else if (jQuery(".tx-webx-bookingemo .searchView form").length > 0)
        itms = jQuery(".tx-webx-bookingemo .searchView form ." + $(this).data('cat') ).find(':' + $(this).data('itm'));

    itms.prop('checked', false);
    $(this).parent().remove();
    shown = $('.fCurrent .fCTarget');
    if( shown.length == 1 ) jQuery('.tx-webx-bookingemo .resetFilter').removeClass('filterSet');
    // console.log("submitting");
    $('.tx-webx-bookingemo .emofilters form').submit();

});

jQuery(".tx-webx-bookingemo .resetFilter").click( function(e) {
    var checkboxes = null;
    if(jQuery(".tx-webx-bookingemo .eventFilterView form").length> 0 )
        checkboxes = jQuery(".tx-webx-bookingemo .eventFilterView form").find(':checkbox');
    else if (jQuery(".tx-webx-bookingemo .infrastructureFilterView form").length > 0)
        checkboxes = jQuery(".tx-webx-bookingemo .infrastructureFilterView form").find(':checkbox');
    else if (jQuery(".tx-webx-bookingemo .searchView form").length > 0)
        checkboxes = jQuery(".tx-webx-bookingemo .searchView form").find(':checkbox');

    if (checkboxes) checkboxes.prop('checked', false);

    if(jQuery(".tx-webx-bookingemo .eventFilterView form").length> 0 )
        options = jQuery(".tx-webx-bookingemo .eventFilterView form").find('select').find(':selected');
    if(jQuery(".tx-webx-bookingemo .infrastructureFilterView form").length> 0 )
        options = jQuery(".tx-webx-bookingemo .infrastructureFilterView form").find('select').find(':selected');
    if(jQuery(".tx-webx-bookingemo .searchView form").length> 0 )
        options = jQuery(".tx-webx-bookingemo .searchView form").find('select').find(':selected');

    if(options) options.prop('selected',false);

    if(jQuery(".tx-webx-bookingemo .eventFilterView form").length> 0 )
        textFields = jQuery(".tx-webx-bookingemo .eventFilterView form").find(':text');
    if(jQuery(".tx-webx-bookingemo .infrastructureFilterView form").length> 0 )
        textFields = jQuery(".tx-webx-bookingemo .infrastructureFilterView form").find(':text');
    if(jQuery(".tx-webx-bookingemo .searchView form").length> 0 )
        textFields = jQuery(".tx-webx-bookingemo .searchView form").find(':text');


    if(textFields) textFields.val('');
    textFields.trigger('change');

    jQuery('.tx-webx-bookingemo .fCurrent .rst').remove();
    jQuery('.tx-webx-bookingemo .fCurrent .resetFilter').show();
    jQuery('.tx-webx-bookingemo .resetFilter').removeClass('filterSet');
    // $('.search-choice-close').trigger('click');
    $('.tx-webx-bookingemo .chosen-multiselect').trigger('chosen:updated');

    $('.tx-webx-bookingemo .emofilters .filterform').submit();
});


function createReset(itm, form, check ) {
    elems = form.find(itm);
    allCats = [];
    checked=false;
    /*elems.each( function() {
        cat = $(this).closest('.fWAcc').data('name');
        cls = $(this).closest('.fWAcc').attr('class').split(' ')[1];
        if($.inArray(cat,allCats)=== -1) allCats.push(cat);
        if($(this).is(':' + check) && $('.fCurrent .' + cls).length == 0 ) {
            console.log(cls);
            console.log(cat);
            jQuery('.tx-webx-bookingemo .resetFilter').addClass('filterSet');
            jQuery('.fCurrent').append('<span class="fCTarget"><span class="' + cls + '" data-itm="' + itm.replace(':','') + '" data-cls="' + cls + '" data-cat="' + cat + '">' + cat + '</span></span>')
            jQuery(".tx-webx-bookingemo .fCTarget ." + cls).click( function(e) {
                itms = form.find('.' + jQuery(this).data('cls')).find(itm);
                itms.prop(check, false);
                $(this).parent().remove();
                shown = $('.fCurrent .fCTarget');
                $('.search-choice-close').trigger('click');
                if( shown.length == 1 ) jQuery('.tx-webx-bookingemo .resetFilter').removeClass('filterSet');
                $('.tx-webx-bookingemo .emofilters form').submit();
            });
        }
    });*/

    elems.each( function() {
        cls = $(this).attr('class').split(' ')[0];
        if(jQuery(this).is(':' + check)) {
            if($(this).data('name') && $('.fCurrent .' + cls).length == 0 ) {
                jQuery('.fCurrent .resetFilter').hide();
                jQuery('.fCurrent').append('<span class="fCTarget"><span class="rst '+cls+'"  data-itm="' + itm.replace(':','') + '" data-cls="' +  cls + '" data-cat="' +  $(this).data('name') + '">' + $(this).data('name') + '</span></span>');
                jQuery('.fCurrent .rst').click( function(e) {
                    form.find('.' + $(this).data('cls')).prop(check, false);
                    // console.log($(this).data('cls'));
                    console.log(form.find('.' + cls).prop(check));
                    $(this).parent().remove();
                    shown = $('.fCurrent .fCTarget');
                    $('.tx-webx-bookingemo .chosen-multiselect').trigger('chosen:updated');
                    if( shown.length == 1 ) {
                        jQuery('.tx-webx-bookingemo .resetFilter').removeClass('filterSet');
                        jQuery('.tx-webx-bookingemo .fCurrent .resetFilter').show();
                    }
                    $('.tx-webx-bookingemo .emofilters form').submit();
                })
            }
        } else if ($('.fCurrent .' + cls).length == 1 ) {
                $('.fCurrent .' + cls).parent().remove();
                shown = $('.fCurrent .fCTarget');
                if( shown.length == 1 ) {
                    jQuery('.tx-webx-bookingemo .resetFilter').removeClass('filterSet');
                    jQuery('.tx-webx-bookingemo .fCurrent .resetFilter').show();
                }

            }
    });
    allChecked=false;
    for ( i in allCats ) {
        checkedCat = false;
        toCheck = form.find('.' + allCats[i] + ' ' + itm);
        toCheck.each(function() {
            if( $( this ).is( ':' + check )) checkedCat=true;
        });
        if(checkedCat) {
            allChecked = true;
        } else {
            jQuery(".tx-webx-bookingemo .fCTarget ." + allCats[i]).remove();
        }

    }
    return allChecked;
}

function doFormRequestGeneric( form ) {
    checkboxes = form.find(':checkbox');
    options = form.find('option');
    allCheck = false;

    if( createReset( 'option',form,'selected' )) allCheck = true;
    if( createReset( ':checkbox',form,'checked' )) allCheck = true;


    if(!allCheck) {
        jQuery('.tx-webx-bookingemo .resetFilter').removeClass('filterSet');
        jQuery('.tx-webx-bookingemo .reset').remove();
    }




}





