if (jQuery(window).width() <= 720) {
    jQuery(".tx-webx-bookingemo .searchView.minisearchview .filterWrapper h3").click(function() {
        if (jQuery(this).hasClass("active")) {
            jQuery(this).parents().find('.active').removeClass("active");
            jQuery(this).parents().children('.mobiletoggle').slideUp();

        } else {
            jQuery(this).next().slideToggle();
            jQuery(this).addClass("active");
            jQuery(this).parents().children('.mobiletoggle').slideDown();
        }
    });

    jQuery(".tx-webx-bookingemo .searchView.minisearchview .searchWrapper2 h3").click(function() {
        if (jQuery(this).hasClass("active")) {
            jQuery(this).parents().find('.active').removeClass("active");
            jQuery('.searchWrapper2 .mobiletoggle').slideUp();


        } else {
            jQuery(this).next().slideToggle();
            jQuery(this).addClass("active");
            jQuery('.searchWrapper2 .mobiletoggle').slideDown();
        }

    });

}


