    jQuery.cookie("webxbookingemo_e_backpage", page, { expires : 0.01 });
    jQuery.cookie('webxbookingemo_location', checksum(location.href), { expires : 0.01 });

    // jQuery.cookie(checksum(location+'webxbookingemo_e_back'),jQuery(".tx-webx-bookingemo .eventFilterView form").serialize(), { expires : 0.01 });
