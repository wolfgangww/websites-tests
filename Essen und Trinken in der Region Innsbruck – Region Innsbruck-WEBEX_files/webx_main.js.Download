/* shopping card */
jQuery(document).ready(function(){
    if(jQuery(".tx-webx-bookingemo .detachedShoppingcart ").length > 0) {
        (function() {
            [].slice.call( document.querySelectorAll( '.checkout' ) ).forEach( function( el ) {
                var openCtrl = el.querySelector( '.checkout__button' ),
                    closeCtrls = el.querySelectorAll( '.checkout__cancel' );

                openCtrl.addEventListener( 'click', function(ev) {
                    ev.preventDefault();
                    classie.add( el, 'checkout--active' );
                    jQuery(".tx-webx-bookingemo .detachedShoppingcart").animate({"margin-top": "-10%"});
                } );

                [].slice.call( closeCtrls ).forEach( function( ctrl ) {
                    ctrl.addEventListener( 'click', function() {
                        classie.remove( el, 'checkout--active' );
                        jQuery(".tx-webx-bookingemo .detachedShoppingcart").animate({"margin-top": "-30px"});
                    } );
                } );
            } );
        })();
    }
});
jQuery(".tx-webx-bookingemo .singleView .room .addShoppingCard button").click(function() {
    var uid = jQuery(this).data("productid") + "_1";
    var i = 1;
    while(jQuery("#shoppingCardItemFor" + uid).length > 0) {
        uid = jQuery(this).data("productid") + "_" + i;
        i++;
    }
    //jQuery(".tx-webx-bookingemo .detachedShoppingcart").animate({"margin-top": "-25%"});
    jQuery(".tx-webx-bookingemo .shoppingCardView .emptyMessage").removeClass("show").addClass("hide");
    var item = "#shoppingCardItemFor" + uid;

    jQuery(".tx-webx-bookingemo .shoppingCardView ul").append("<li id='shoppingCardItemFor" + uid + "' data-product='" + uid + "' class='loading future'><span class='imgPlaceholder'></span>" + jQuery(this).data("title") + "<div class='clearfix'></div></li>");
    if(jQuery(".tx-webx-bookingemo .detachedShoppingcart").length > 0) {
        jQuery(".tx-webx-bookingemo .detachedShoppingcart").animate({"margin-top": "-10%"});
        jQuery(".tx-webx-bookingemo .detachedShoppingcart .checkout").addClass("checkout--active");
    }

    setTimeout(function() {
        jQuery(item).removeClass("future");
    },100);

    var searchLine = jQuery(this).data("searchline");
