jQuery(".tx-webx-bookingemo .addNotelist span").click(function() {
    var type = jQuery(this).data("type");
    if(jQuery(".tx-webx-bookingemo .notelistView").length > 0) {
        jQuery(".tx-webx-bookingemo .notelistView ul." + type).append("<li id='notelistItemFor" + jQuery(this).data("uid") + "' data-uid='" + jQuery(this).data("uid") + "' class='loading future'><span class='imgPlaceholder'></span>" + jQuery(this).data("title") + "<div class='clearfix'></div></li>");
        var item = "#notelistItemFor" + jQuery(this).data("uid");
        setTimeout(function(){
            jQuery(item).removeClass("future");
        },100);
        jQuery(".tx-webx-bookingemo .notelistView .emptyMessage").removeClass("show").addClass("hide");
    }
    jQuery(this).closest(".notelistButtons").addClass("loading");
    jQuery(this).closest(".serviceProvider, .singleView, .event, .infrastructure").find(".removeNotelist").toggleClass("show hide");
    jQuery(this).parent().toggleClass("show hide");
    xajax_ajaxModifyNotelist(type, jQuery(this).data("uid"));
});

jQuery(".tx-webx-bookingemo .removeNotelist span").click(function() {
    var type = jQuery(this).data("type");
    if(jQuery(".tx-webx-bookingemo .notelistView").length > 0) {
        jQuery(".tx-webx-bookingemo .notelistView li[data-uid=" + jQuery(this).data("uid") + "]").addClass("loading").find("span").hide();

        if(jQuery(".tx-webx-bookingemo .notelistView li").not(".loading").length == 0)
            jQuery(".tx-webx-bookingemo .notelistView .emptyMessage").removeClass("hide").addClass("show");
    }
    jQuery(this).closest(".notelistButtons").addClass("loading");
    jQuery(this).closest(".serviceProvider, .singleView, .event, .infrastructure").find(".addNotelist").toggleClass("show hide");
    jQuery(this).parent().toggleClass("show hide");
    xajax_ajaxModifyNotelist(type, jQuery(this).data("uid"));
});

