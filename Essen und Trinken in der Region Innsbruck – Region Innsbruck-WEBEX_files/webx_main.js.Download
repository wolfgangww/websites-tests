        var item = "#shoppingCardItemFor" + uid;

        jQuery(".tx-webx-bookingemo .shoppingCardView ul").append("<li id='shoppingCardItemFor" + uid + "' data-product='" + uid + "' class='loading future'><span class='imgPlaceholder'></span>" + jQuery(this).data("title") + "<div class='clearfix'></div></li>");
        if(jQuery(".tx-webx-bookingemo .detachedShoppingcart").length > 0) {
            jQuery(".tx-webx-bookingemo .detachedShoppingcart").animate({"margin-top": "-10%"});
            jQuery(".tx-webx-bookingemo .detachedShoppingcart .checkout").addClass("checkout--active");
        }

        setTimeout(function() {
            jQuery(item).removeClass("future");
        },100);

        var dataruid = jQuery(this).data("ruid");
        var mealcode = jQuery(".tx-webx-bookingemo .singleView #" + dataruid + " input[type=radio][name=mealcode]:checked").val();
        console.log(dataruid + " -- " + mealcode);

        var searchLine = jQuery(this).data("searchline");
        if (searchLine) {
            EmoAjax_ajaxModifyShoppingCard(uid, 'product', Number(searchLine), mealcode);
        } else {
            EmoAjax_ajaxModifyShoppingCard(uid);
        }
    });

    /* singleview */
    jQuery(".tx-webx-bookingemo .singleView .room .anfragen").click(function(e){
        e.preventDefault();
        jQuery(".tx-webx-bookingemo  .tabs .tab[data-tab=enquiry]").trigger("click");
        jQuery("#enquiry .rooms").show();
        var parent = jQuery(this).closest(".room");
        jQuery("html, body").animate({ scrollTop: jQuery("#enquiry").offset().top + "px" });
        jQuery("#enquiry .rooms ul").append("<li class='future'><input type='hidden' name='tx_webxbookingemo_main[newEnquiry][relProducts][]' value='" + parent.data("uid") + "'/><div class='image'>" + parent.find(".image").html() + "</div><div class='emoButton glyphicon glyphicon-trash removeRoom pull-right'></div><div class='infos'>" + parent.find(".infos .roomTitle").html() + "</div><div class='clearfix'></div></li>")
        setTimeout(function(){
            jQuery("#enquiry .rooms ul li").last().removeClass("future");
        },100);

        rebindSingle();
    });

    function rebindSingle() {
        jQuery("#enquiry ul li .removeRoom").unbind("click").click(function(){
            var item = jQuery(this).closest("li");
            item.addClass("past");
            setTimeout(function(){
                item.remove();
                if(jQuery("#enquiry .rooms ul li").length == 0)
                    jQuery("#enquiry .rooms").hide();
            },500);
        });
    }

    jQuery(".tooltipster").tooltipster({
        theme: 'tooltipster-wc',
        contentAsHTML: true
    });

    jQuery('input[type=radio][name=mealcode]').change(function() {
        var dataruid = jQuery(this).closest('form').data('ruid');
        var val = jQuery(".tx-webx-bookingemo .singleView #" + dataruid + " input[type=radio][name=mealcode]:checked").val();
        //console.log(val);
        //console.log(dataruid);
        /*
         jQuery(".tx-webx-bookingemo .singleView #" + dataruid + " .displayPriceProduct").hide();
         jQuery(".tx-webx-bookingemo .singleView #" + dataruid + " .mealcode_" + val).show();
         */
        jQuery(".tx-webx-bookingemo .singleView #" + dataruid + " .displayPriceProduct").removeClass("bold");
        jQuery(".tx-webx-bookingemo .singleView #" + dataruid + " .displayPriceProduct.mealcode_" + val).addClass("bold");
    });
    jQuery("form.mealcodeRadio").each(function (index, element) {
        var dataruid = jQuery(this).data("ruid");
        console.log(dataruid);
        jQuery("#" + dataruid + " input[type=radio][name=mealcode]:first").attr("checked", true).trigger("change");
    });

    jQuery('.detailRoomsTab').each(function() {
        jQuery(this).css('cursor','default');
    });
    jQuery('.detailPackagesTab').each(function() {
        jQuery(this).css('cursor','pointer');
    });
    jQuery('.detailRoomsTab').click(function() {
        jQuery('.detailPackagesTab').removeClass('active').css('cursor','pointer');
        jQuery(this).addClass('active').css('cursor','default');
        jQuery('.detailPackages').addClass('hidden');
        jQuery('.detailRooms').removeClass('hidden');
    });
    jQuery('.detailPackagesTab').click(function() {
        jQuery('.detailRoomsTab').removeClass('active').css('cursor','pointer');
        jQuery(this).addClass('active').css('cursor','default');
        jQuery('.detailRooms').addClass('hidden');
        jQuery('.detailPackages').removeClass('hidden');
    });

}

