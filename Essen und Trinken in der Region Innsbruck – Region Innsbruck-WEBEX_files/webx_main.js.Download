            firstSearch = false;
            $(this).html('');
            EmoAjax_ajaxSearch(jQuery.cookie("webxbookingemo_u_back"), jQuery.cookie("webxbookingemo_u_filter"), jQuery.cookie("webxbookingemo_u_backpage"), $(this).data());
