/* searchview */
jQuery(document).ready(function(){
    jQuery(".tx-webx-bookingemo .searchView .roomWrapper").each(function(){
        var val = jQuery(this).find(".children").val();
        var parent = jQuery(this);
        parent.find(".childrenAge").css("width", (100 / val) - 1.5 + "%");
    });
});
jQuery(".tx-webx-bookingemo .searchView .children").change(function(){
    var val = jQuery(this).val();
    var parent = jQuery(this).closest(".roomWrapper");

    parent.find(".childrenAge").attr("style","display:none;").css("width", (100 / val) - 1.5 + "%");
    for(i = 1; i <= parent.find(".childrenAge").length;i++) {
        if(i <= val) {
            parent.find(".childrenAge" + i).show();
            parent.find(".childrenAge" + i).parent().show();
        } else {
            parent.find(".childrenAge" + i).hide();
            parent.find(".childrenAge" + i).parent().hide();
        }
    }

    if(val > 0)
        parent.find(".childrenAgeWrapper").slideDown("fast");
    else
        parent.find(".childrenAgeWrapper").slideUp("fast");
});
jQuery("#searchRooms").change(function(){
    var val = jQuery(this).val();

    for(i = 1; i < jQuery(".tx-webx-bookingemo .searchView .more .roomWrapper").length;i++) {
        if(i <= val)
            jQuery(".tx-webx-bookingemo .searchView .more .roomWrapper" + i).slideDown("fast");
        else {
            jQuery(".tx-webx-bookingemo .searchView .more .roomWrapper" + i).slideUp("fast");
        }
    }
});
